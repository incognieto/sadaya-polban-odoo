<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ========== SEARCH VIEW ========== -->
    <record model="ir.ui.view" id="view_si_plang_paket_search">
      <field name="name">si_plang.paket.search</field>
      <field name="model">si_plang.paket</field>
      <field name="arch" type="xml">
        <search string="Cari Paket">
          <field name="name" string="Nama Paket"/>
          <field name="unit_pengusul"/>
          <filter string="Barang" name="filter_barang"
                  domain="[('jenis_pengadaan','=','barang')]"/>
          <filter string="Jasa Lainnya" name="filter_jasa_lainnya"
                  domain="[('jenis_pengadaan','=','jasa_lainnya')]"/>
          <filter string="Konstruksi" name="filter_konstruksi"
                  domain="[('jenis_pengadaan','=','konstruksi')]"/>
          <filter string="Jasa Konsultansi" name="filter_jasa_konsultansi"
                  domain="[('jenis_pengadaan','=','jasa_konsultansi')]"/>
          <separator/>
          <filter string="Aktif" name="filter_active"
                  domain="[('status_paket','not in',['batal','selesai'])]"/>
          <filter string="Selesai" name="filter_selesai"
                  domain="[('status_paket','=','selesai')]"/>
          <filter string="Batal" name="filter_batal"
                  domain="[('status_paket','=','batal')]"/>
          <separator/>
          <filter string="Group by Status" name="group_status"
                  context="{'group_by': 'status_paket'}"/>
          <filter string="Group by Jenis" name="group_jenis"
                  context="{'group_by': 'jenis_pengadaan'}"/>
        </search>
      </field>
    </record>

    <!-- ========== LIST VIEW ========== -->
    <record model="ir.ui.view" id="view_si_plang_paket_list">
      <field name="name">si_plang.paket.list</field>
      <field name="model">si_plang.paket</field>
      <field name="arch" type="xml">
        <list string="Paket Pengadaan Langsung">
          <field name="name" string="Nama Paket"/>
          <field name="unit_pengusul" string="Unit Pengusul"/>
          <field name="jenis_pengadaan" string="Jenis Pengadaan"/>
          <field name="nilai_hps" string="Nilai HPS"/>
          <field name="status_paket" string="Status" widget="badge"/>
          <field name="tanggal" string="Tanggal"/>
        </list>
      </field>
    </record>

    <!-- ========== FORM VIEW ========== -->
    <record model="ir.ui.view" id="view_si_plang_paket_form">
      <field name="name">si_plang.paket.form</field>
      <field name="model">si_plang.paket</field>
      <field name="arch" type="xml">
        <form string="Paket Pengadaan Langsung">
          <header>
            <!-- BPMN Step 1→2: Pemicu → Input Paket -->
            <button name="action_input_paket" type="object"
                    string="Input Paket Pengadaan"
                    class="btn-primary"
                    invisible="status_paket != 'draft'"/>

            <!-- BPMN Step 2→3: Input Paket → Submit Penawaran -->
            <button name="action_submit_penawaran" type="object"
                    string="Submit Penawaran Vendor"
                    class="btn-primary"
                    invisible="status_paket != 'input_paket'"/>

            <!-- BPMN Step 3→4: Submit Penawaran → Seleksi & Validasi -->
            <button name="action_seleksi_validasi" type="object"
                    string="Seleksi &amp; Validasi"
                    class="btn-primary"
                    invisible="status_paket != 'penawaran'"/>

            <!-- BPMN Step 4→5: Seleksi → Terbitkan SPK -->
            <button name="action_terbitkan_spk" type="object"
                    string="Terbitkan SPK"
                    class="btn-success"
                    invisible="status_paket != 'seleksi'"/>

            <!-- BPMN Step 5→6: Terbit SPK → Selesai -->
            <button name="action_selesai" type="object"
                    string="Selesai Pengadaan"
                    class="btn-success"
                    invisible="status_paket != 'terbit_spk'"/>

            <!-- Exception buttons -->
            <button name="action_batal" type="object" string="Batalkan"
                    class="btn-danger"
                    invisible="status_paket in ('batal','selesai')"/>
            <button name="action_reset_draft" type="object" string="Reset ke Draft"
                    invisible="status_paket != 'batal'"/>

            <!-- Statusbar -->
            <field name="status_paket" widget="statusbar"
                   statusbar_visible="draft,input_paket,penawaran,seleksi,terbit_spk,selesai"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="name" placeholder="Nama Paket..."/>
              </h1>
            </div>
            <group>
              <group string="Informasi Paket">
                <field name="unit_pengusul"/>
                <field name="jenis_pengadaan"/>
                <field name="nilai_hps"/>
                <field name="vendor_pemenang_id" readonly="1"/>
              </group>
              <group string="Jadwal">
                <field name="tanggal"/>
                <field name="tanggal_mulai"/>
                <field name="tanggal_selesai"/>
              </group>
            </group>
            <notebook>
              <page string="Daftar Barang / Jasa" name="items_page">
                <field name="item_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="name"/>
                    <field name="deskripsi"/>
                    <field name="qty"/>
                    <field name="satuan"/>
                    <field name="harga_satuan"/>
                    <field name="subtotal" sum="Total HPS"/>
                  </list>
                </field>
              </page>
              <page string="Penawaran Vendor" name="penawaran_page">
                <field name="penawaran_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="vendor_id"/>
                    <field name="harga_penawaran"/>
                    <field name="tanggal"/>
                    <field name="dokumen_penawaran" filename="dokumen_filename"/>
                    <field name="dokumen_filename" column_invisible="1"/>
                    <field name="catatan"/>
                    <field name="status_penawaran" widget="badge"/>
                    <button name="action_pilih_pemenang" type="object"
                            string="✓ Pilih" class="btn-success"
                            icon="fa-check"/>
                    <button name="action_tolak" type="object"
                            string="✗ Tolak" class="btn-link text-danger"
                            icon="fa-times"/>
                  </list>
                </field>
              </page>
              <page string="Kontrak / SPK" name="kontrak_page">
                <field name="kontrak_ids" nolabel="1">
                  <list>
                    <field name="name"/>
                    <field name="pejabat_pembuat"/>
                    <field name="penyedia"/>
                    <field name="status_kontrak" widget="badge"/>
                    <field name="tanggal"/>
                  </list>
                </field>
              </page>
              <page string="Keterangan" name="keterangan_page">
                <field name="keterangan" nolabel="1" placeholder="Catatan tambahan..."/>
              </page>
            </notebook>
          </sheet>
          <chatter/>
        </form>
      </field>
    </record>

    <!-- ========== ACTION ========== -->
    <record model="ir.actions.act_window" id="action_si_plang_paket">
      <field name="name">Paket Pengadaan Langsung</field>
      <field name="res_model">si_plang.paket</field>
      <field name="view_mode">list,form</field>
      <field name="context">{}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Belum ada paket tersedia.
        </p>
        <p>Klik tombol <b>Baru</b> untuk menambahkan paket pengadaan pertama.</p>
      </field>
    </record>

  </data>
</odoo>
