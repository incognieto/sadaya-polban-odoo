<odoo>
  <data>
    <!-- Form view definition -->
    <record model="ir.ui.view" id="si_plang.form">
      <field name="name">SiPlang Form</field>
      <field name="model">si_plang.si_plang</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="value"/>
              <field name="value2"/>
              <field name="description"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- List view definition -->
    <record model="ir.ui.view" id="si_plang.list">
      <field name="name">SiPlang List</field>
      <field name="model">si_plang.si_plang</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="value"/>
          <field name="value2"/>
        </list>
      </field>
    </record>

    <!-- Action opening views on models -->
    <record model="ir.actions.act_window" id="si_plang.action_window">
      <field name="name">SiPlang</field>
      <field name="res_model">si_plang.si_plang</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- Top menu item -->
    <menuitem name="SiPlang" id="si_plang.menu_root"/>

    <!-- Menu item for list view -->
    <menuitem name="SiPlang Records" id="si_plang.menu_1" parent="si_plang.menu_root"
              action="si_plang.action_window"/>
  </data>
</odoo>
