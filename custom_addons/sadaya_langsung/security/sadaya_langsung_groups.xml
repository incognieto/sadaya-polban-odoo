<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <record id="group_sadaya_langsung_vendor" model="res.groups">
      <field name="name">Vendor Sadaya Langsung</field>
      <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="rule_sadaya_langsung_penawaran_vendor" model="ir.rule">
      <field name="name">Vendor hanya melihat penawarannya sendiri</field>
      <field name="model_id" ref="model_sadaya_langsung_penawaran"/>
      <field name="domain_force">[('vendor_id', '=', user.partner_id.id)]</field>
      <field name="groups" eval="[(4, ref('sadaya_langsung.group_sadaya_langsung_vendor'))]"/>
    </record>

    <record id="rule_sadaya_langsung_paket_vendor" model="ir.rule">
      <field name="name">Vendor hanya melihat paket yang diundang untuknya</field>
      <field name="model_id" ref="model_sadaya_langsung_paket"/>
      <field name="domain_force">[('penawaran_ids.vendor_id', '=', user.partner_id.id)]</field>
      <field name="groups" eval="[(4, ref('sadaya_langsung.group_sadaya_langsung_vendor'))]"/>
    </record>
  </data>
</odoo>
