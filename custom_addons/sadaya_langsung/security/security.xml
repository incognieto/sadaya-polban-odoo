<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_langsung_pokja" model="res.groups">
            <field name="name">POKJA Langsung (Admin Lelang)</field>
        </record>

        <record id="group_langsung_unit_kerja" model="res.groups">
            <field name="name">Unit Kerja Langsung (Viewer)</field>
        </record>

        <record id="sadaya_auth.user_alice_pokja" model="res.users">
            <field name="groups_id" eval="[(4, ref('sadaya_langsung.group_langsung_pokja'))]"/>
        </record>

        <record id="sadaya_auth.user_eve_unitkerja" model="res.users">
            <field name="groups_id" eval="[(4, ref('sadaya_langsung.group_langsung_unit_kerja'))]"/>
        </record>
    </data>
</odoo>
