<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ========== SEARCH VIEW ========== -->
    <record model="ir.ui.view" id="view_sadaya_langsung_paket_search">
      <field name="name">sadaya_langsung.paket.search</field>
      <field name="model">sadaya_langsung.paket</field>
      <field name="arch" type="xml">
        <search string="Cari Paket">
          <field name="name" string="Nama Paket"/>
          <field name="unit_pengusul"/>
          <filter string="Barang" name="filter_barang"
                  domain="[('jenis_pengadaan','=','barang')]"/>
          <filter string="Jasa Lainnya" name="filter_jasa_lainnya"
                  domain="[('jenis_pengadaan','=','jasa_lainnya')]"/>
          <filter string="Konstruksi" name="filter_konstruksi"
                  domain="[('jenis_pengadaan','=','konstruksi')]"/>
          <filter string="Jasa Konsultansi" name="filter_jasa_konsultansi"
                  domain="[('jenis_pengadaan','=','jasa_konsultansi')]"/>
          <separator/>
          <filter string="Aktif" name="filter_active"
                  domain="[('status_paket','not in',['batal','spk_dibuat'])]"/>
          <filter string="Selesai (SPK)" name="filter_selesai"
                  domain="[('status_paket','=','spk_dibuat')]"/>
          <filter string="Batal" name="filter_batal"
                  domain="[('status_paket','=','batal')]"/>
          <separator/>
          <filter string="Group by Status" name="group_status"
                  context="{'group_by': 'status_paket'}"/>
          <filter string="Group by Jenis" name="group_jenis"
                  context="{'group_by': 'jenis_pengadaan'}"/>
        </search>
      </field>
    </record>

    <!-- ========== LIST VIEW ========== -->
    <record model="ir.ui.view" id="view_sadaya_langsung_paket_kanban">
      <field name="name">sadaya_langsung.paket.kanban</field>
      <field name="model">sadaya_langsung.paket</field>
      <field name="arch" type="xml">
        <kanban class="o_kanban_small_column">
          <field name="name"/>
          <field name="unit_pengusul"/>
          <field name="jenis_pengadaan"/>
          <field name="status_paket"/>
          <templates>
            <t t-name="card">
              <div class="oe_kanban_card">
                <div class="o_kanban_header">
                  <strong><field name="name"/></strong>
                </div>
                <div class="o_kanban_content">
                  <div><strong>Unit:</strong> <field name="unit_pengusul"/></div>
                  <div><strong>Jenis:</strong> <field name="jenis_pengadaan"/></div>
                  <div><strong>Status:</strong> <field name="status_paket"/></div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <record model="ir.ui.view" id="view_sadaya_langsung_paket_list">
      <field name="name">sadaya_langsung.paket.list</field>
      <field name="model">sadaya_langsung.paket</field>
      <field name="arch" type="xml">
        <list string="Paket Sadaya Langsung">
          <field name="unit_pengusul" string="Unit Pengusul"/>
          <field name="name" string="Nama Paket"/>
          <field name="jenis_pengadaan" string="Jenis Pengadaan"/>
          <field name="status_paket" string="Status" widget="badge"/>
          <field name="tanggal_mulai" string="Tanggal Mulai"/>
        </list>
      </field>
    </record>

    <!-- ========== FORM VIEW ========== -->
    <record model="ir.ui.view" id="view_sadaya_langsung_paket_form">
      <field name="name">sadaya_langsung.paket.form</field>
      <field name="model">sadaya_langsung.paket</field>
      <field name="arch" type="xml">
        <form string="Paket Sadaya Langsung">
          <header>
            <button name="action_ajukan" type="object"
                    string="Ajukan Persetujuan"
                    class="btn-primary"
                    invisible="status_paket != 'draft'"/>

            <button name="action_pengumuman" type="object"
                    string="Publikasi &amp; Pengumuman"
                    class="btn-primary"
                    invisible="status_paket != 'menunggu_persetujuan'"/>

            <button name="action_pendaftaran" type="object"
                    string="Buka Pendaftaran"
                    class="btn-primary"
                    invisible="status_paket != 'pengumuman'"/>

            <button name="action_pemasukan_penawaran" type="object"
                    string="Mulai Pemasukan Penawaran"
                    class="btn-primary"
                    invisible="status_paket != 'pendaftaran_peserta'"/>

            <button name="action_pembukaan_penawaran" type="object"
                    string="Buka Penawaran"
                    class="btn-primary"
                    invisible="status_paket != 'pemasukan_penawaran'"/>

            <button name="action_evaluasi" type="object"
                    string="Evaluasi Dokumen"
                    class="btn-primary"
                    invisible="status_paket != 'pembukaan_penawaran'"/>

            <button name="action_pembuktian_kualifikasi" type="object"
                    string="Pembuktian Kualifikasi"
                    class="btn-primary"
                    invisible="status_paket != 'evaluasi'"/>

            <button name="action_negosiasi" type="object"
                    string="Klarifikasi &amp; Negosiasi"
                    class="btn-primary"
                    invisible="status_paket not in ('evaluasi','pembuktian_kualifikasi')"/>

            <button name="action_tetapkan_pemenang" type="object"
                    string="Tetapkan Pemenang"
                    class="btn-success"
                    invisible="status_paket != 'negosiasi'"/>

            <button name="action_buat_spk" type="object"
                    string="Buat SPK / Kontrak"
                    class="btn-success"
                    invisible="status_paket != 'penetapan'"/>

            <!-- Exception buttons -->
            <button name="action_batal" type="object" string="Batalkan"
                    class="btn-danger"
                    invisible="status_paket in ('batal','spk_dibuat')"/>
            <button name="action_reset_draft" type="object" string="Reset ke Draft"
                    invisible="status_paket != 'batal'"/>

            <!-- Statusbar -->
            <field name="status_paket" widget="statusbar"
                   statusbar_visible="draft,pengumuman,pendaftaran_peserta,pemasukan_penawaran,evaluasi,negosiasi,penetapan,spk_dibuat"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="name" placeholder="Nama Paket..."/>
              </h1>
            </div>
            <group>
              <group string="Informasi Paket">
                <field name="unit_pengusul"/>
                <field name="contract_count" readonly="1"/>
                <field name="jenis_pengadaan"/>
                <field name="vendor_pemenang_id" string="Vendor Pemenang"
                       invisible="status_paket in ('draft','menunggu_persetujuan','pengumuman','pendaftaran_peserta','pemasukan_penawaran','pembukaan_penawaran','evaluasi','pembuktian_kualifikasi','negosiasi')"/>
                <field name="status_paket" string="Status Paket"/>
              </group>
              <group string="Jadwal">
                <field name="tanggal"/>
                <field name="tanggal_mulai"/>
                <field name="tanggal_selesai"/>
              </group>
            </group>
            <notebook>
              <page string="Dokumen Persiapan" name="dokumen_persiapan_page">
                <group>
                  <field name="dokumen_kak" filename="filename_kak"/>
                  <field name="filename_kak" invisible="1"/>
                  <field name="dokumen_rab" filename="filename_rab"/>
                  <field name="filename_rab" invisible="1"/>
                </group>
              </page>
              <page string="Daftar Barang / Jasa" name="items_page">
                <field name="item_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="name"/>
                    <field name="deskripsi"/>
                    <field name="qty"/>
                    <field name="satuan"/>
                    <field name="harga_satuan"/>
                    <field name="subtotal" sum="Total HPS"/>
                  </list>
                </field>
              </page>
              <page string="Pengolahan Penawaran" name="penawaran_page">
                <field name="penawaran_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="vendor_id" domain="[('is_sadaya_mitra_vendor','=',True)]"/>
                    <field name="harga_penawaran"/>
                    <field name="dokumen_penawaran" filename="dokumen_filename"/>
                    <field name="dokumen_filename" column_invisible="1"/>
                    <field name="evaluasi_administrasi" widget="badge"/>
                    <field name="evaluasi_teknis" widget="badge"/>
                    <field name="evaluasi_harga" widget="badge"/>
                    <field name="lulus_evaluasi" readonly="1"/>
                    <field name="status_penawaran" widget="badge"/>
                    <button name="action_pilih_pemenang" type="object"
                            string="✓ Tetapkan" class="btn-success"
                            icon="fa-check"/>
                    <button name="action_tolak" type="object"
                            string="✗ Tolak" class="btn-link text-danger"
                            icon="fa-times"/>
                  </list>
                </field>
              </page>
              <page string="Klarifikasi &amp; Negosiasi" name="negosiasi_page">
                <group>
                  <field name="catatan_negosiasi" placeholder="Masukkan log catatan proses negosiasi harga dan teknis dengan vendor..."/>
                  <field name="harga_sepakat" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </group>
              </page>
              <page string="Kontrak / SPK" name="kontrak_page">
                <field name="kontrak_ids" nolabel="1">
                  <list>
                    <field name="name"/>
                    <field name="pejabat_pembuat"/>
                    <field name="penyedia"/>
                    <field name="status_kontrak" widget="badge"/>
                    <field name="tanggal"/>
                  </list>
                </field>
              </page>
              <page string="Keterangan" name="keterangan_page">
                <field name="keterangan" nolabel="1" placeholder="Catatan tambahan..."/>
              </page>
            </notebook>
          </sheet>
          <chatter/>
        </form>
      </field>
    </record>

    <!-- ========== ACTION ========== -->
    <record model="ir.actions.act_url" id="action_sadaya_langsung_dashboard_url">
      <field name="name">Dashboard</field>
      <field name="url">/sadaya_langsung</field>
      <field name="target">self</field>
    </record>

    <record model="ir.actions.act_url" id="action_sadaya_langsung_paket_url">
      <field name="name">Paket Sadaya Langsung</field>
      <field name="url">/sadaya_langsung/paket</field>
      <field name="target">self</field>
    </record>

  </data>
</odoo>
