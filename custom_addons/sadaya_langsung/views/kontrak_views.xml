<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ========== SEARCH VIEW ========== -->
    <record model="ir.ui.view" id="view_sadaya_langsung_kontrak_search">
      <field name="name">sadaya_langsung.kontrak.search</field>
      <field name="model">sadaya_langsung.kontrak</field>
      <field name="arch" type="xml">
        <search string="Cari Kontrak">
          <field name="name" string="Nama Paket"/>
          <field name="pejabat_pembuat"/>
          <field name="penyedia"/>
          <filter string="Barang" name="filter_barang"
                  domain="[('jenis_pengadaan','=','barang')]"/>
          <filter string="Jasa Lainnya" name="filter_jasa_lainnya"
                  domain="[('jenis_pengadaan','=','jasa_lainnya')]"/>
          <filter string="Konstruksi" name="filter_konstruksi"
                  domain="[('jenis_pengadaan','=','konstruksi')]"/>
          <filter string="Jasa Konsultansi" name="filter_jasa_konsultansi"
                  domain="[('jenis_pengadaan','=','jasa_konsultansi')]"/>
          <separator/>
          <filter string="PAM" name="filter_pam"
                  domain="[('status_kontrak','=','pam')]"/>
          <filter string="Persiapan" name="filter_persiapan"
                  domain="[('status_kontrak','=','persiapan_kontrak')]"/>
          <filter string="Proses" name="filter_proses"
                  domain="[('status_kontrak','=','proses_tte')]"/>
          <filter string="Selesai" name="filter_selesai"
                  domain="[('status_kontrak','=','selesai_kontrak')]"/>
          <separator/>
          <filter string="Status" name="group_status"
                  context="{'group_by': 'status_kontrak'}"/>
          <filter string="Jenis Pengadaan" name="group_jenis"
                  context="{'group_by': 'jenis_pengadaan'}"/>
        </search>
      </field>
    </record>

    <!-- ========== LIST VIEW ========== -->
    <record model="ir.ui.view" id="view_sadaya_langsung_kontrak_list">
      <field name="name">sadaya_langsung.kontrak.list</field>
      <field name="model">sadaya_langsung.kontrak</field>
      <field name="arch" type="xml">
        <list string="Daftar Kontrak">
          <field name="name" string="Nama Paket"/>
          <field name="pejabat_pembuat" string="Pejabat Pembuat"/>
          <field name="penyedia" string="Penyedia"/>
          <field name="jenis_pengadaan" string="Jenis Pengadaan"/>
          <field name="nilai_hps" string="Nilai HPS"/>
          <field name="status_kontrak" string="Status" widget="badge"/>
          <field name="tanggal" string="Tanggal"/>
        </list>
      </field>
    </record>

    <!-- ========== FORM VIEW ========== -->
    <record model="ir.ui.view" id="view_sadaya_langsung_kontrak_form">
      <field name="name">sadaya_langsung.kontrak.form</field>
      <field name="model">sadaya_langsung.kontrak</field>
      <field name="arch" type="xml">
        <form string="Kontrak">
          <header>
            <button name="action_persiapan_kontrak" type="object" string="Selesai PAM (Lanjut Persiapan)"
                    class="btn-primary"
                    invisible="status_kontrak != 'pam'"/>
            <button name="action_proses_tte" type="object" string="Proses TTE"
                    class="btn-primary"
                    invisible="status_kontrak != 'persiapan_kontrak'"/>
            <button name="action_pelaksanaan" type="object" string="Mulai Pelaksanaan"
                    class="btn-primary"
                    invisible="status_kontrak != 'proses_tte'"/>
            <button name="action_pemeriksaan" type="object" string="Pemeriksaan PPHP"
                    class="btn-primary"
                    invisible="status_kontrak != 'pelaksanaan'"/>
            <button name="action_selesai_kontrak" type="object" string="Selesai Kontrak"
                    class="btn-success"
                    invisible="status_kontrak != 'pemeriksaan'"/>
            <button name="action_revisi" type="object" string="Revisi"
                    invisible="status_kontrak in ('selesai_kontrak','revisi')"/>
            <button name="action_addendum" type="object" string="Addendum"
                    invisible="status_kontrak != 'selesai_kontrak'"/>
            <button name="action_batal" type="object" string="Batal"
                    class="btn-danger"
                    invisible="status_kontrak in ('selesai_kontrak','batal')"/>
            <field name="status_kontrak" widget="statusbar"
                   statusbar_visible="pam,persiapan_kontrak,proses_tte,pelaksanaan,pemeriksaan,selesai_kontrak"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="name" placeholder="Nama kontrak..."/>
              </h1>
            </div>
            <group>
              <group>
                <field name="paket_id"/>
                <field name="jenis_pengadaan"/>
              </group>
              <group>
                <field name="status_kontrak"/>
                <field name="nilai_hps"/>
              </group>
            </group>

            <group>
              <group>
                <field name="pejabat_pembuat"/>
                <field name="penyedia"/>
              </group>
              <group>
                <field name="tanggal"/>
                <field name="tanggal_mulai"/>
                <field name="tanggal_selesai"/>
              </group>
            </group>

            <notebook>
              <page string="Chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="activity_ids" widget="mail_activity"/>
                <field name="message_ids" widget="mail_thread"/>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- ========== ACTION ========== -->
    <record model="ir.actions.act_url" id="action_sadaya_langsung_kontrak_url">
      <field name="name">Kontrak</field>
      <field name="url">/sadaya-langsung/kontrak</field>
      <field name="target">self</field>
    </record>

    <record model="ir.actions.act_window" id="action_sadaya_langsung_kontrak_admin">
      <field name="name">Kontrak Sadaya Langsung</field>
      <field name="res_model">sadaya_langsung.kontrak</field>
      <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
