<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_sadaya_registration_list" model="ir.ui.view">
        <field name="name">sadaya.registration.list</field>
        <field name="model">sadaya.registration</field>
        <field name="arch" type="xml">
            <list>
                <field name="nama_lengkap"/>
                <field name="email"/>
                <field name="whatsapp_narahubung"/>
                <field name="state" widget="badge" decoration-success="state=='approved'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_sadaya_registration_form" model="ir.ui.view">
        <field name="name">sadaya.registration.form</field>
        <field name="model">sadaya.registration</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="nama_lengkap"/>
                        <field name="email"/>
                        <field name="whatsapp_narahubung"/>
                        <field name="tipe_pendaftar"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sadaya_registration" model="ir.actions.act_window">
        <field name="name">Sadaya Registration</field>
        <field name="res_model">sadaya.registration</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_sadaya_root"
              name="Sadaya"/>

    <menuitem id="menu_sadaya_registration"
              name="Registrations"
              parent="menu_sadaya_root"
              action="action_sadaya_registration"/>

</odoo>