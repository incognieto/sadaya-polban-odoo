<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================
         SADAYA BASE LAYOUT (untuk halaman auth)
         ============================================ -->
    <template id="sadaya_layout_auth" name="Sadaya Auth Layout">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="head">
                <link rel="stylesheet" t-att-href="'/sadaya_auth/static/src/css/sadaya_main.css?v=1.0.9'"/>
            </t>

            <div class="sadaya-auth-page d-flex min-vh-100 bg-light">
                <!-- Panel Kiri: Branding (Navy Blue) -->
                <div class="sadaya-auth-panel-left d-none d-lg-flex flex-column justify-content-center text-white p-5" style="background: linear-gradient(135deg, #062846 0%, #031424 100%);">
                    <div class="sadaya-auth-brand mb-5">
                        <div class="sadaya-auth-brand-logo bg-white text-primary rounded-3 d-flex align-items-center justify-content-center fw-bold mb-3" style="width: 56px; height: 56px; font-size: 2rem; line-height: 56px;">
                            S
                        </div>
                        <h1 class="fw-bold mb-1">Sadaya</h1>
                        <p class="text-white-50">Platform Pengadaan Barang &amp; Jasa Digital</p>
                    </div>

                    <div class="sadaya-auth-features d-flex flex-column gap-4">
                        <div class="d-flex align-items-start gap-3">
                            <div class="fs-4 rounded p-2 text-center" style="width: 42px; height: 42px; background: rgba(255,255,255,0.1); line-height: 1;">🏛️</div>
                            <div>
                                <h6 class="fw-bold mb-1 text-white">Terpercaya &amp; Terverifikasi</h6>
                                <p class="text-white-50 small mb-0">Setiap vendor diverifikasi NIK dan dokumen resmi perusahaan</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start gap-3">
                            <div class="fs-4 rounded p-2 text-center" style="width: 42px; height: 42px; background: rgba(255,255,255,0.1); line-height: 1;">📋</div>
                            <div>
                                <h6 class="fw-bold mb-1 text-white">Pengadaan Transparan</h6>
                                <p class="text-white-50 small mb-0">Proses tender dan seleksi vendor yang adil dan akuntabel</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start gap-3">
                            <div class="fs-4 rounded p-2 text-center" style="width: 42px; height: 42px; background: rgba(255,255,255,0.1); line-height: 1;">🔒</div>
                            <div>
                                <h6 class="fw-bold mb-1 text-white">Keamanan Data</h6>
                                <p class="text-white-50 small mb-0">Data Anda dilindungi dengan enkripsi tingkat enterprise</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start gap-3">
                            <div class="fs-4 rounded p-2 text-center" style="width: 42px; height: 42px; background: rgba(255,255,255,0.1); line-height: 1;">⚡</div>
                            <div>
                                <h6 class="fw-bold mb-1 text-white">Proses Cepat</h6>
                                <p class="text-white-50 small mb-0">Pengadaan digital yang efisien dan hemat waktu</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Panel Kanan: Form (White) -->
                <div class="sadaya-auth-panel-right flex-grow-1 d-flex flex-column justify-content-between p-4 p-md-5 bg-white">
                    <div class="my-auto mx-auto w-100" style="max-width: 480px;">
                        <t t-out="0"/>
                    </div>

                </div>
            </div>

            <script t-att-src="'/sadaya_auth/static/src/js/sadaya_auth.js?v=1.0.9'"/>
            <script t-att-src="'/sadaya_auth/static/src/js/sadaya_register.js?v=1.0.9'"/>
        </t>
    </template>

    <!-- ============================================
         SADAYA APP LAYOUT (setelah login)
         ============================================ -->
    <template id="sadaya_layout_app" name="Sadaya App Layout">
        <t t-call="website.layout">
            <t t-set="head">
                <link rel="stylesheet" t-att-href="'/sadaya_auth/static/src/css/sadaya_main.css?v=1.0.9'"/>
            </t>

            <div id="wrap" class="oe_structure oe_empty d-flex flex-column" style="min-height: calc(100vh - 70px);">
                <div class="container my-5 sadaya-animate-fade">
                    <div class="row">
                        <!-- Sidebar Menu -->
                        <aside class="col-lg-3 col-md-4 mb-4">
                            <div class="list-group shadow-sm border rounded-3 overflow-hidden">
                                <div class="list-group-item bg-light border-0 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px; font-size: 1.1rem;">
                                            <t t-out="(request.env.user.name or 'U')[0].upper()"/>
                                        </div>
                                        <div class="overflow-hidden">
                                            <h6 class="mb-0 text-truncate fw-bold text-dark"><t t-out="request.env.user.name"/></h6>
                                            <small class="text-muted text-truncate d-block"><t t-out="request.env.user.email"/></small>
                                        </div>
                                    </div>
                                </div>
                                <div class="list-group-item bg-light fw-bold text-muted text-uppercase small border-top px-3 py-2" style="font-size: 0.7rem; letter-spacing: 0.08em;">Menu Utama</div>
                                <a href="/sadaya/dashboard" class="list-group-item list-group-item-action d-flex align-items-center gap-2 border-0 px-3 py-2">
                                    <span>🏠</span> Dashboard
                                </a>
                                <a href="/sadaya-mitra/profil" class="list-group-item list-group-item-action d-flex align-items-center gap-2 border-0 px-3 py-2">
                                    <span>👤</span> Profil Saya
                                </a>
                                <div class="list-group-item bg-light fw-bold text-muted text-uppercase small border-top px-3 py-2" style="font-size: 0.7rem; letter-spacing: 0.08em;">Akun</div>
                                <a href="/sadaya/logout" class="list-group-item list-group-item-action text-danger d-flex align-items-center gap-2 border-0 px-3 py-2">
                                    <span>🚪</span> Keluar
                                </a>
                            </div>
                        </aside>
                        <!-- Main Content -->
                        <main class="col-lg-9 col-md-8">
                            <t t-out="0"/>
                        </main>
                    </div>
                </div>

            </div>

            <script t-att-src="'/sadaya_auth/static/src/js/sadaya_auth.js?v=1.0.9'"/>
        </t>
    </template>

</odoo>
