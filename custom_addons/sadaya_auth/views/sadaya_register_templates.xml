<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================
         HELPER MACRO: FILE UPLOAD
         ============================================ -->
    <template id="sadaya_file_upload_widget">
        <t t-set="accept_val" t-value="accept or 'image/*'"/>
        <div class="sadaya-file-upload" t-att-class="'is-invalid' if error else ''">
            <input type="file" t-att-id="field_id" t-att-name="field_name"
                   t-att-accept="accept_val" t-att-required="required_val"/>
            <div class="sadaya-file-upload-icon">📎</div>
            <div class="sadaya-file-upload-text">
                <strong>Pilih file</strong> atau drag &amp; drop di sini
            </div>
        </div>
        <t t-if="error">
            <div class="sadaya-field-error">⚠ <t t-esc="error"/></div>
        </t>
        <div class="sadaya-file-preview" t-att-id="field_id + '_preview'"></div>
    </template>

    <!-- ============================================
         HALAMAN PILIH TIPE REGISTRASI
         ============================================ -->
    <template id="sadaya_register_select" name="Sadaya - Pilih Tipe Registrasi">
        <t t-call="sadaya_auth.sadaya_layout_auth">
            <t t-set="title">Daftar Akun</t>

            <!-- Tabs -->
            <div class="sadaya-auth-tabs">
                <button class="sadaya-auth-tab active" onclick="window.location='/sadaya/register/badan-usaha'">
                    🏢 Badan Usaha
                </button>
                <button class="sadaya-auth-tab" onclick="window.location='/sadaya/register/perorangan'">
                    👤 Perorangan
                </button>
            </div>

            <h2 class="sadaya-auth-title">Daftar Akun Sadaya</h2>
            <p class="sadaya-auth-subtitle">
                Pilih tipe pendaftaran Anda, atau
                <a href="/sadaya/login">Sudah memiliki akun? Masuk</a>
            </p>

            <div style="display:flex; flex-direction:column; gap:1rem; margin-top:1rem;">
                <a href="/sadaya/register/badan-usaha" class="sadaya-card" style="text-decoration:none; transition:all 0.2s;">
                    <div class="sadaya-card-body" style="display:flex; gap:1rem; align-items:center;">
                        <div style="font-size:2.5rem;">🏢</div>
                        <div>
                            <div style="font-weight:700; color:var(--sadaya-text); margin-bottom:0.25rem;">Badan Usaha</div>
                            <div style="font-size:0.85rem; color:var(--sadaya-text-muted);">
                                PT, CV, Firma, Koperasi, atau badan hukum lainnya
                            </div>
                        </div>
                        <div style="margin-left:auto; color:var(--sadaya-primary);">→</div>
                    </div>
                </a>

                <a href="/sadaya/register/perorangan" class="sadaya-card" style="text-decoration:none;">
                    <div class="sadaya-card-body" style="display:flex; gap:1rem; align-items:center;">
                        <div style="font-size:2.5rem;">👤</div>
                        <div>
                            <div style="font-weight:700; color:var(--sadaya-text); margin-bottom:0.25rem;">Perorangan</div>
                            <div style="font-size:0.85rem; color:var(--sadaya-text-muted);">
                                Individu atau usaha perseorangan
                            </div>
                        </div>
                        <div style="margin-left:auto; color:var(--sadaya-primary);">→</div>
                    </div>
                </a>
            </div>
        </t>
    </template>

    <!-- ============================================
         REGISTRASI BADAN USAHA
         ============================================ -->
    <template id="sadaya_register_badan_usaha" name="Sadaya - Registrasi Badan Usaha">
        <t t-call="sadaya_auth.sadaya_layout_auth">
            <t t-set="title">Daftar Badan Usaha</t>

            <!-- Tabs -->
            <div class="sadaya-auth-tabs">
                <button class="sadaya-auth-tab active" data-tab="badan_usaha">🏢 Badan Usaha</button>
                <button class="sadaya-auth-tab" data-tab="perorangan" onclick="window.location='/sadaya/register/perorangan'">👤 Perorangan</button>
            </div>

            <h2 class="sadaya-auth-title">Daftar</h2>
            <p class="sadaya-auth-subtitle">
                Sudah memiliki akun?
                <a href="/sadaya/login">Masuk</a>
            </p>

            <!-- Global Error -->
            <t t-if="error and error.get('general')">
                <div class="sadaya-alert sadaya-alert-error">
                    ⚠ <t t-esc="error['general']"/>
                </div>
            </t>

            <form id="sadaya-register-form" action="/sadaya/register/submit"
                  method="post" enctype="multipart/form-data" novalidate="novalidate">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="tipe_pendaftar" value="badan_usaha"/>

                <!-- ===== INFORMASI BADAN USAHA ===== -->
                <div class="sadaya-form-section">
                    <div class="sadaya-form-section-title">🏢 Informasi Badan Usaha</div>
                </div>

                <!-- Nama Badan Usaha -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="nama_badan_usaha">
                        Nama Badan Usaha <span class="required">*</span>
                    </label>
                    <input type="text" id="nama_badan_usaha" name="nama_badan_usaha"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('nama_badan_usaha') else 'sadaya-input'"
                           placeholder="Nama Badan Usaha"
                           t-att-value="form_data.get('nama_badan_usaha', '')"
                           required="required"/>
                    <t t-if="error and error.get('nama_badan_usaha')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['nama_badan_usaha']"/></div>
                    </t>
                </div>

                <!-- Email -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="email">
                        Email <span class="required">*</span>
                    </label>
                    <input type="email" id="email" name="email"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('email') else 'sadaya-input'"
                           placeholder="Email"
                           t-att-value="form_data.get('email', '')"
                           required="required"/>
                    <t t-if="error and error.get('email')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['email']"/></div>
                    </t>
                </div>

                <!-- Kata Sandi -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="password">
                        Kata Sandi <span class="required">*</span>
                    </label>
                    <div style="position:relative;">
                        <input type="password" id="password" name="password"
                               class="sadaya-input"
                               t-att-class="'sadaya-input is-invalid' if error and error.get('password') else 'sadaya-input'"
                               placeholder="Kata Sandi"
                               required="required" style="padding-right:3rem;"/>
                        <button type="button" data-sadaya-toggle-pwd="password"
                                style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1rem;">
                            👁️
                        </button>
                    </div>
                    <div class="sadaya-pwd-strength" style="margin-top:0.5rem;">
                        <div class="sadaya-pwd-bars">
                            <div class="sadaya-pwd-bar"></div>
                            <div class="sadaya-pwd-bar"></div>
                            <div class="sadaya-pwd-bar"></div>
                            <div class="sadaya-pwd-bar"></div>
                        </div>
                        <div class="sadaya-pwd-label sadaya-input-hint">
                            Harus berisi setidaknya satu angka dan satu huruf besar dan kecil, dan setidaknya 8 karakter atau lebih, contoh: 1Rstigapuluh
                        </div>
                    </div>
                    <t t-if="error and error.get('password')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['password']"/></div>
                    </t>
                </div>

                <!-- Konfirmasi Kata Sandi -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="password_confirm">
                        Konfirmasi Kata Sandi <span class="required">*</span>
                    </label>
                    <div style="position:relative;">
                        <input type="password" id="password_confirm" name="password_confirm"
                               class="sadaya-input"
                               t-att-class="'sadaya-input is-invalid' if error and error.get('password_confirm') else 'sadaya-input'"
                               placeholder="Konfirmasi Kata Sandi"
                               required="required" style="padding-right:3rem;"/>
                        <button type="button" data-sadaya-toggle-pwd="password_confirm"
                                style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1rem;">
                            👁️
                        </button>
                    </div>
                    <t t-if="error and error.get('password_confirm')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['password_confirm']"/></div>
                    </t>
                </div>

                <!-- Telepon Badan Usaha -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="telepon_badan_usaha">
                        Telepon Badan Usaha <span class="required">*</span>
                    </label>
                    <input type="tel" id="telepon_badan_usaha" name="telepon_badan_usaha"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('telepon_badan_usaha') else 'sadaya-input'"
                           placeholder="+628123456789"
                           t-att-value="form_data.get('telepon_badan_usaha', '')"
                           data-sadaya-phone="1"
                           required="required"/>
                    <div class="sadaya-input-hint">Contoh: +628123456789</div>
                    <t t-if="error and error.get('telepon_badan_usaha')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['telepon_badan_usaha']"/></div>
                    </t>
                </div>

                <!-- ===== NARAHUBUNG ===== -->
                <div class="sadaya-form-section">
                    <div class="sadaya-form-section-title">👤 Informasi Narahubung</div>
                </div>

                <!-- Nama Lengkap Narahubung -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="nama_lengkap">
                        Nama Lengkap Narahubung <span class="required">*</span>
                    </label>
                    <input type="text" id="nama_lengkap" name="nama_lengkap"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('nama_lengkap') else 'sadaya-input'"
                           placeholder="Nama Lengkap Narahubung"
                           t-att-value="form_data.get('nama_lengkap', '')"
                           required="required"/>
                    <t t-if="error and error.get('nama_lengkap')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['nama_lengkap']"/></div>
                    </t>
                </div>

                <!-- WhatsApp Narahubung -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="whatsapp_narahubung">
                        Nomor WhatsApp Narahubung <span class="required">*</span>
                    </label>
                    <input type="tel" id="whatsapp_narahubung" name="whatsapp_narahubung"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('whatsapp_narahubung') else 'sadaya-input'"
                           placeholder="+628123456789"
                           t-att-value="form_data.get('whatsapp_narahubung', '')"
                           data-sadaya-phone="1"
                           required="required"/>
                    <div class="sadaya-input-hint">Contoh: +628123456789</div>
                    <t t-if="error and error.get('whatsapp_narahubung')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['whatsapp_narahubung']"/></div>
                    </t>
                </div>

                <!-- NIK Narahubung -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="nik_narahubung">
                        Nomor NIK Narahubung <span class="required">*</span>
                    </label>
                    <input type="text" id="nik_narahubung" name="nik_narahubung"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('nik_narahubung') else 'sadaya-input'"
                           placeholder="Nomor NIK Narahubung"
                           t-att-value="form_data.get('nik_narahubung', '')"
                           data-sadaya-nik="1"
                           maxlength="16"
                           required="required"/>
                    <div class="sadaya-input-hint">Panjang NIK harus terdiri dari 16 digit.</div>
                    <t t-if="error and error.get('nik_narahubung')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['nik_narahubung']"/></div>
                    </t>
                </div>

                <!-- Swafoto Narahubung (KTP) -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label">
                        Swafoto Narahubung (Memegang KTP) <span class="required">*</span>
                    </label>
                    <div class="sadaya-file-upload" t-att-class="'sadaya-file-upload is-invalid' if error and error.get('swafoto_ktp') else 'sadaya-file-upload'">
                        <input type="file" id="swafoto_ktp" name="swafoto_ktp"
                               accept=".jpg,.jpeg,.png" required="required"/>
                        <div class="sadaya-file-upload-icon">📸</div>
                        <div class="sadaya-file-upload-text">
                            <strong>Pilih file</strong> atau drag &amp; drop<br/>
                            <small style="color:var(--sadaya-text-muted)">JPEG/JPG/PNG • Maks. 10 MB</small>
                        </div>
                    </div>
                    <div class="sadaya-file-preview" id="swafoto_ktp_preview"></div>
                    <t t-if="error and error.get('swafoto_ktp')">
                        <div class="sadaya-field-error" id="swafoto_error">⚠ <t t-esc="error['swafoto_ktp']"/></div>
                    </t>
                    <t t-else="">
                        <div id="swafoto_error" class="sadaya-field-error"></div>
                    </t>
                    <div class="sadaya-input-hint">
                        Harap unggah dokumen dengan ekstensi JPEG/JPG/PNG dengan ukuran maksimal 10 mb
                    </div>
                </div>

                <!-- ===== NPWP (Opsional) ===== -->
                <div class="sadaya-form-section">
                    <div class="sadaya-form-section-title">📄 Dokumen NPWP <span style="font-weight:400;color:var(--sadaya-text-muted);font-size:0.75rem;">(Opsional)</span></div>
                </div>

                <!-- Nomor NPWP -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="npwp_perusahaan">Nomor NPWP Perusahaan</label>
                    <input type="text" id="npwp_perusahaan" name="npwp_perusahaan"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('npwp_perusahaan') else 'sadaya-input'"
                           placeholder="16 digit NPWP"
                           t-att-value="form_data.get('npwp_perusahaan', '')"
                           data-sadaya-npwp="1"
                           maxlength="16"/>
                    <div class="sadaya-input-hint">Panjang NPWP harus terdiri dari 16 digit.</div>
                    <t t-if="error and error.get('npwp_perusahaan')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['npwp_perusahaan']"/></div>
                    </t>
                </div>

                <!-- Bukti NPWP -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label">
                        Bukti NPWP <span class="required">*</span>
                    </label>
                    <div class="sadaya-file-upload" t-att-class="'sadaya-file-upload is-invalid' if error and error.get('bukti_npwp') else 'sadaya-file-upload'">
                        <input type="file" id="bukti_npwp" name="bukti_npwp" accept=".pdf"/>
                        <div class="sadaya-file-upload-icon">📄</div>
                        <div class="sadaya-file-upload-text">
                            <strong>Pilih file PDF</strong> atau drag &amp; drop<br/>
                            <small style="color:var(--sadaya-text-muted)">PDF • Maks. 10 MB</small>
                        </div>
                    </div>
                    <div class="sadaya-file-preview" id="bukti_npwp_preview"></div>
                    <t t-if="error and error.get('bukti_npwp')">
                        <div class="sadaya-field-error" id="bukti_npwp_error">⚠ <t t-esc="error['bukti_npwp']"/></div>
                    </t>
                    <t t-else="">
                        <div id="bukti_npwp_error" class="sadaya-field-error"></div>
                    </t>
                    <div class="sadaya-input-hint">
                        Harap unggah dokumen dengan ekstensi PDF dengan ukuran maksimal 10 mb
                    </div>
                </div>

                <!-- Submit -->
                <div style="margin-top:1.5rem;">
                    <button type="submit" class="sadaya-btn sadaya-btn-primary sadaya-btn-full sadaya-btn-lg sadaya-form-submit">
                        Daftar
                    </button>
                    <div style="text-align:center; margin-top:1rem; font-size:0.875rem; color:var(--sadaya-text-muted);">
                        Sudah memiliki akun?
                        <a href="/sadaya/login" style="color:var(--sadaya-primary); font-weight:600;">Masuk</a>
                    </div>
                </div>
            </form>
        </t>
    </template>

    <!-- ============================================
         REGISTRASI PERORANGAN
         ============================================ -->
    <template id="sadaya_register_perorangan" name="Sadaya - Registrasi Perorangan">
        <t t-call="sadaya_auth.sadaya_layout_auth">
            <t t-set="title">Daftar Perorangan</t>

            <!-- Tabs -->
            <div class="sadaya-auth-tabs">
                <button class="sadaya-auth-tab" data-tab="badan_usaha" onclick="window.location='/sadaya/register/badan-usaha'">🏢 Badan Usaha</button>
                <button class="sadaya-auth-tab active" data-tab="perorangan">👤 Perorangan</button>
            </div>

            <h2 class="sadaya-auth-title">Daftar</h2>
            <p class="sadaya-auth-subtitle">
                Sudah memiliki akun?
                <a href="/sadaya/login">Masuk</a>
            </p>

            <!-- Global Error -->
            <t t-if="error and error.get('general')">
                <div class="sadaya-alert sadaya-alert-error">
                    ⚠ <t t-esc="error['general']"/>
                </div>
            </t>

            <form id="sadaya-register-form" action="/sadaya/register/submit"
                  method="post" enctype="multipart/form-data" novalidate="novalidate">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="tipe_pendaftar" value="perorangan"/>

                <!-- Nama -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="nama_lengkap">
                        Nama <span class="required">*</span>
                    </label>
                    <input type="text" id="nama_lengkap" name="nama_lengkap"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('nama_lengkap') else 'sadaya-input'"
                           placeholder="Nama Lengkap"
                           t-att-value="form_data.get('nama_lengkap', '')"
                           required="required"/>
                    <t t-if="error and error.get('nama_lengkap')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['nama_lengkap']"/></div>
                    </t>
                </div>

                <!-- Email -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="email">
                        Email <span class="required">*</span>
                    </label>
                    <input type="email" id="email" name="email"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('email') else 'sadaya-input'"
                           placeholder="Email"
                           t-att-value="form_data.get('email', '')"
                           required="required"/>
                    <t t-if="error and error.get('email')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['email']"/></div>
                    </t>
                </div>

                <!-- Kata Sandi -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="password">
                        Kata Sandi <span class="required">*</span>
                    </label>
                    <div style="position:relative;">
                        <input type="password" id="password" name="password"
                               class="sadaya-input"
                               t-att-class="'sadaya-input is-invalid' if error and error.get('password') else 'sadaya-input'"
                               placeholder="Kata Sandi"
                               required="required" style="padding-right:3rem;"/>
                        <button type="button" data-sadaya-toggle-pwd="password"
                                style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1rem;">
                            👁️
                        </button>
                    </div>
                    <div class="sadaya-pwd-strength" style="margin-top:0.5rem;">
                        <div class="sadaya-pwd-bars">
                            <div class="sadaya-pwd-bar"></div>
                            <div class="sadaya-pwd-bar"></div>
                            <div class="sadaya-pwd-bar"></div>
                            <div class="sadaya-pwd-bar"></div>
                        </div>
                        <div class="sadaya-pwd-label sadaya-input-hint">
                            Harus berisi setidaknya satu angka dan satu huruf besar dan kecil, dan setidaknya 8 karakter atau lebih, contoh: 1Rstigapuluh
                        </div>
                    </div>
                    <t t-if="error and error.get('password')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['password']"/></div>
                    </t>
                </div>

                <!-- Konfirmasi Kata Sandi -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="password_confirm">
                        Konfirmasi Kata Sandi <span class="required">*</span>
                    </label>
                    <div style="position:relative;">
                        <input type="password" id="password_confirm" name="password_confirm"
                               class="sadaya-input"
                               t-att-class="'sadaya-input is-invalid' if error and error.get('password_confirm') else 'sadaya-input'"
                               placeholder="Konfirmasi Kata Sandi"
                               required="required" style="padding-right:3rem;"/>
                        <button type="button" data-sadaya-toggle-pwd="password_confirm"
                                style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1rem;">
                            👁️
                        </button>
                    </div>
                    <t t-if="error and error.get('password_confirm')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['password_confirm']"/></div>
                    </t>
                </div>

                <!-- Nomor WhatsApp -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="whatsapp_narahubung">
                        Nomor WhatsApp <span class="required">*</span>
                    </label>
                    <input type="tel" id="whatsapp_narahubung" name="whatsapp_narahubung"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('whatsapp_narahubung') else 'sadaya-input'"
                           placeholder="+628123456789"
                           t-att-value="form_data.get('whatsapp_narahubung', '')"
                           data-sadaya-phone="1"
                           required="required"/>
                    <div class="sadaya-input-hint">Minimal 12 Digit</div>
                    <t t-if="error and error.get('whatsapp_narahubung')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['whatsapp_narahubung']"/></div>
                    </t>
                </div>

                <!-- NIK -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="nik_narahubung">
                        NIK <span class="required">*</span>
                    </label>
                    <input type="text" id="nik_narahubung" name="nik_narahubung"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('nik_narahubung') else 'sadaya-input'"
                           placeholder="16 digit NIK"
                           t-att-value="form_data.get('nik_narahubung', '')"
                           data-sadaya-nik="1"
                           maxlength="16"
                           required="required"/>
                    <div class="sadaya-input-hint">Minimal 16 Digit</div>
                    <t t-if="error and error.get('nik_narahubung')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['nik_narahubung']"/></div>
                    </t>
                </div>

                <!-- Swafoto (Memegang KTP) -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label">
                        Swafoto (Memegang KTP) <span class="required">*</span>
                    </label>
                    <div class="sadaya-file-upload" t-att-class="'sadaya-file-upload is-invalid' if error and error.get('swafoto_ktp') else 'sadaya-file-upload'">
                        <input type="file" id="swafoto_ktp" name="swafoto_ktp"
                               accept=".jpg,.jpeg,.png" required="required"/>
                        <div class="sadaya-file-upload-icon">📸</div>
                        <div class="sadaya-file-upload-text">
                            <strong>Pilih file</strong> atau drag &amp; drop<br/>
                            <small style="color:var(--sadaya-text-muted)">JPEG/JPG/PNG • Maks. 10 MB</small>
                        </div>
                    </div>
                    <div class="sadaya-file-preview" id="swafoto_ktp_preview"></div>
                    <t t-if="error and error.get('swafoto_ktp')">
                        <div class="sadaya-field-error" id="swafoto_error">⚠ <t t-esc="error['swafoto_ktp']"/></div>
                    </t>
                    <t t-else="">
                        <div id="swafoto_error" class="sadaya-field-error"></div>
                    </t>
                    <div class="sadaya-input-hint">
                        Harap unggah dokumen dengan ekstensi JPEG/JPG/PNG dengan ukuran maksimal 10 mb
                    </div>
                </div>

                <!-- NPWP Opsional -->
                <div class="sadaya-form-section">
                    <div class="sadaya-form-section-title">📄 NPWP <span style="font-weight:400;color:var(--sadaya-text-muted);font-size:0.75rem;">(Opsional)</span></div>
                </div>

                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="npwp_perusahaan">Nomor NPWP</label>
                    <input type="text" id="npwp_perusahaan" name="npwp_perusahaan"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('npwp_perusahaan') else 'sadaya-input'"
                           placeholder="16 digit NPWP"
                           t-att-value="form_data.get('npwp_perusahaan', '')"
                           data-sadaya-npwp="1"
                           maxlength="16"/>
                    <div class="sadaya-input-hint">Panjang NPWP harus terdiri dari 16 digit.</div>
                    <t t-if="error and error.get('npwp_perusahaan')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['npwp_perusahaan']"/></div>
                    </t>
                </div>

                <div class="sadaya-form-group">
                    <label class="sadaya-label">
                        Bukti NPWP <span class="required">*</span>
                    </label>
                    <div class="sadaya-file-upload" t-att-class="'sadaya-file-upload is-invalid' if error and error.get('bukti_npwp') else 'sadaya-file-upload'">
                        <input type="file" id="bukti_npwp" name="bukti_npwp" accept=".pdf"/>
                        <div class="sadaya-file-upload-icon">📄</div>
                        <div class="sadaya-file-upload-text">
                            <strong>Pilih file PDF</strong> atau drag &amp; drop<br/>
                            <small style="color:var(--sadaya-text-muted)">PDF • Maks. 10 MB</small>
                        </div>
                    </div>
                    <div class="sadaya-file-preview" id="bukti_npwp_preview"></div>
                    <t t-if="error and error.get('bukti_npwp')">
                        <div class="sadaya-field-error" id="bukti_npwp_error">⚠ <t t-esc="error['bukti_npwp']"/></div>
                    </t>
                    <t t-else="">
                        <div id="bukti_npwp_error" class="sadaya-field-error"></div>
                    </t>
                    <div class="sadaya-input-hint">
                        Harap unggah dokumen dengan ekstensi PDF dengan ukuran maksimal 10 mb
                    </div>
                </div>

                <!-- Submit -->
                <div style="margin-top:1.5rem;">
                    <button type="submit" class="sadaya-btn sadaya-btn-primary sadaya-btn-full sadaya-btn-lg sadaya-form-submit">
                        Daftar
                    </button>
                    <div style="text-align:center; margin-top:1rem; font-size:0.875rem; color:var(--sadaya-text-muted);">
                        Sudah memiliki akun?
                        <a href="/sadaya/login" style="color:var(--sadaya-primary); font-weight:600;">Masuk</a>
                    </div>
                </div>
            </form>
        </t>
    </template>

    <!-- ============================================
         SUKSES REGISTRASI
         ============================================ -->
    <template id="sadaya_register_success" name="Sadaya - Registrasi Berhasil">
        <t t-call="sadaya_auth.sadaya_layout_auth">
            <t t-set="title">Registrasi Berhasil</t>

            <div style="text-align:center; padding: 2rem 0;">
                <div style="font-size:4rem; margin-bottom:1rem;">✅</div>
                <h2 class="sadaya-auth-title">Pendaftaran Berhasil!</h2>
                <p style="color:var(--sadaya-text-muted); margin-bottom:1.5rem;">
                    Terima kasih telah mendaftar di Sadaya.<br/>
                    Akun Anda sedang dalam proses verifikasi.
                </p>

                <div class="sadaya-alert sadaya-alert-info" style="text-align:left;">
                    📧 Kami akan menghubungi Anda melalui email
                    <t t-if="email">
                        <strong> <t t-esc="email"/> </strong>
                    </t>
                    setelah proses verifikasi selesai (biasanya 1-3 hari kerja).
                </div>

                <div style="margin-top:1.5rem;">
                    <a href="/sadaya/login" class="sadaya-btn sadaya-btn-primary sadaya-btn-lg">
                        Ke Halaman Login
                    </a>
                </div>
            </div>
        </t>
    </template>

</odoo>
