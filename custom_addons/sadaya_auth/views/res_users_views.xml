<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_sadaya_registration_list" model="ir.ui.view">
        <field name="name">sadaya.registration.list</field>
        <field name="model">sadaya.registration</field>
        <field name="arch" type="xml">
            <list string="Registrations">
                <field name="nama_lengkap"/>
                <field name="email"/>
                <field name="whatsapp_narahubung" string="WhatsApp"/>
                <field name="nik_narahubung" string="NIK"/>
                <field name="tipe_pendaftar"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_sadaya_registration_form" model="ir.ui.view">
        <field name="name">sadaya.registration.form</field>
        <field name="model">sadaya.registration</field>
        <field name="arch" type="xml">
            <form string="Registration">
                <sheet>
                    <group>
                        <field name="nama_lengkap"/>
                        <field name="email"/>
                        <field name="whatsapp_narahubung" string="WhatsApp"/>
                        <field name="nik_narahubung" string="NIK"/>
                        <field name="tipe_pendaftar"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_sadaya_registration_search" model="ir.ui.view">
        <field name="name">sadaya.registration.search</field>
        <field name="model">sadaya.registration</field>
        <field name="arch" type="xml">
            <search string="Search Registrations">
                <field name="nama_lengkap"/>
                <field name="email"/>
                <field name="whatsapp_narahubung" string="WhatsApp"/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state','=','rejected')]"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sadaya_registration" model="ir.actions.act_window">
        <field name="name">Sadaya Registration</field>
        <field name="res_model">sadaya.registration</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sadaya_registration_search"/>
    </record>

    <!-- MENU -->
    <menuitem id="menu_sadaya_root"
              name="Sadaya"/>

    <menuitem id="menu_sadaya_registration"
              name="Registrations"
              parent="menu_sadaya_root"
              action="action_sadaya_registration"/>

</odoo>