<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================
         HALAMAN LOGIN SADAYA
         ============================================ -->
    <template id="sadaya_login" name="Sadaya - Login">
        <t t-call="sadaya_auth.sadaya_layout_auth">
            <t t-set="title">Masuk</t>

            <div style="margin-bottom:2rem;">
                <h2 class="sadaya-auth-title">Masuk ke Sadaya</h2>
                <p class="sadaya-auth-subtitle">
                    Belum punya akun?
                    <a href="/sadaya/register">Daftar sekarang</a>
                </p>
            </div>

            <!-- Alert sukses logout -->
            <t t-if="request.params.get('success') == 'logout'">
                <div class="sadaya-alert sadaya-alert-success">
                    ✓ Anda telah berhasil keluar dari aplikasi.
                </div>
            </t>

            <!-- Global Error -->
            <t t-if="error and error.get('general')">
                <div class="sadaya-alert sadaya-alert-error">
                    ⚠ <t t-esc="error['general']"/>
                </div>
            </t>

            <form action="/sadaya/login/submit" method="post" id="sadaya-login-form" novalidate="novalidate">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="redirect" t-att-value="redirect or '/sadaya/dashboard'"/>

                <!-- Email -->
                <div class="sadaya-form-group">
                    <label class="sadaya-label" for="email">
                        Email <span class="required">*</span>
                    </label>
                    <input type="email" id="email" name="email"
                           class="sadaya-input"
                           t-att-class="'sadaya-input is-invalid' if error and error.get('email') else 'sadaya-input'"
                           placeholder="Masukkan email Anda"
                           t-att-value="form_data.get('email', '') if form_data else ''"
                           autocomplete="email"
                           required="required"
                           autofocus="autofocus"/>
                    <t t-if="error and error.get('email')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['email']"/></div>
                    </t>
                </div>

                <!-- Kata Sandi -->
                <div class="sadaya-form-group">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.4rem;">
                        <label class="sadaya-label" for="password" style="margin-bottom:0;">
                            Kata Sandi <span class="required">*</span>
                        </label>
                        <a href="/web/reset_password" style="font-size:0.8rem; color:var(--sadaya-primary); text-decoration:none; font-weight:500;">
                            Lupa kata sandi?
                        </a>
                    </div>
                    <div style="position:relative;">
                        <input type="password" id="password" name="password"
                               class="sadaya-input"
                               t-att-class="'sadaya-input is-invalid' if error and error.get('password') else 'sadaya-input'"
                               placeholder="Masukkan kata sandi"
                               autocomplete="current-password"
                               required="required"
                               style="padding-right:3rem;"/>
                        <button type="button" data-sadaya-toggle-pwd="password"
                                style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1rem;"
                                aria-label="Tampilkan/sembunyikan kata sandi">
                            👁️
                        </button>
                    </div>
                    <t t-if="error and error.get('password')">
                        <div class="sadaya-field-error">⚠ <t t-esc="error['password']"/></div>
                    </t>
                </div>

                <!-- Remember me -->
                <div class="sadaya-form-group" style="display:flex; align-items:center; gap:0.5rem;">
                    <input type="checkbox" id="remember_me" name="remember_me"
                           style="width:16px; height:16px; accent-color:var(--sadaya-primary); cursor:pointer;"/>
                    <label for="remember_me" style="font-size:0.875rem; color:var(--sadaya-text-muted); cursor:pointer; margin:0;">
                        Ingat saya
                    </label>
                </div>

                <!-- Submit -->
                <div style="margin-top:1.25rem;">
                    <button type="submit" class="sadaya-btn sadaya-btn-primary sadaya-btn-full sadaya-btn-lg sadaya-form-submit">
                        Masuk
                    </button>
                </div>

                <div style="text-align:center; margin-top:1.25rem; font-size:0.875rem; color:var(--sadaya-text-muted);">
                    Belum memiliki akun?
                    <a href="/sadaya/register" style="color:var(--sadaya-primary); font-weight:600;">Daftar</a>
                </div>
            </form>

            <!-- Info Box -->
            <div class="sadaya-info-box" style="margin-top:1.5rem;">
                <strong>ℹ️ Catatan:</strong> Akun Anda harus sudah diverifikasi oleh admin sebelum dapat masuk.
                Jika belum menerima konfirmasi, hubungi <strong>support@sadaya.id</strong>
            </div>
        </t>
    </template>

</odoo>
