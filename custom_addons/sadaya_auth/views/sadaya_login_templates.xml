<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================
         HALAMAN LOGIN SADAYA
         ============================================ -->
    <template id="sadaya_login" name="Sadaya - Login">
        <t t-call="sadaya_auth.sadaya_layout_auth">
            <t t-set="title">Masuk</t>

            <div class="text-center mb-4">
                <h3 class="fw-bold text-dark mb-1">Masuk ke Sadaya</h3>
                <p class="text-muted small">
                    Belum punya akun?
                    <a href="/sadaya/register" class="fw-bold text-primary text-decoration-none">Daftar sekarang</a>
                </p>
            </div>

            <!-- Alert sukses logout -->
            <t t-if="request.params.get('success') == 'logout'">
                <div class="alert alert-success d-flex align-items-center gap-2 mb-3">
                    <span>✓</span> Anda telah berhasil keluar dari aplikasi.
                </div>
            </t>

            <!-- Global Error -->
            <t t-if="error and error.get('general')">
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-3">
                    <span>⚠</span> <t t-esc="error['general']"/>
                </div>
            </t>

            <form action="/sadaya/login/submit" method="post" id="sadaya-login-form" novalidate="novalidate">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="redirect" t-att-value="redirect or '/sadaya/dashboard'"/>

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label fw-bold small text-dark" for="email">
                        Email <span class="text-danger">*</span>
                    </label>
                    <input type="email" id="email" name="email"
                           class="form-control"
                           t-att-class="'form-control is-invalid' if error and error.get('email') else 'form-control'"
                           placeholder="Masukkan email Anda"
                           t-att-value="form_data.get('email', '') if form_data else ''"
                           autocomplete="email"
                           required="required"
                           autofocus="autofocus"/>
                    <t t-if="error and error.get('email')">
                        <div class="text-danger small mt-1">⚠ <t t-esc="error['email']"/></div>
                    </t>
                </div>

                <!-- Kata Sandi -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label fw-bold small text-dark mb-0" for="password">
                            Kata Sandi <span class="text-danger">*</span>
                        </label>
                        <a href="/web/reset_password" class="small text-primary text-decoration-none">
                            Lupa kata sandi?
                        </a>
                    </div>
                    <div class="input-group">
                        <input type="password" id="password" name="password"
                               class="form-control"
                               t-att-class="'form-control is-invalid' if error and error.get('password') else 'form-control'"
                               placeholder="Masukkan kata sandi"
                               autocomplete="current-password"
                               required="required"/>
                        <button class="btn btn-outline-secondary" type="button" data-sadaya-toggle-pwd="password"
                                aria-label="Tampilkan/sembunyikan kata sandi">
                            <i class="fa fa-eye"/>
                        </button>
                    </div>
                    <t t-if="error and error.get('password')">
                        <div class="text-danger small mt-1">⚠ <t t-esc="error['password']"/></div>
                    </t>
                </div>

                <!-- Remember me -->
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="remember_me" name="remember_me" style="cursor:pointer;"/>
                    <label class="form-check-label text-muted small" for="remember_me" style="cursor:pointer;">
                        Ingat saya
                    </label>
                </div>

                <!-- Submit -->
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold sadaya-form-submit">
                        Masuk
                    </button>
                </div>

                <div class="text-center mt-3 small text-muted">
                    Belum memiliki akun?
                    <a href="/sadaya/register" class="fw-bold text-primary text-decoration-none">Daftar</a>
                </div>
            </form>

            <!-- Info Box -->
            <div class="alert alert-info small mt-4 mb-0">
                <strong>ℹ️ Catatan:</strong> Akun Anda harus sudah diverifikasi oleh admin sebelum dapat masuk.
                Jika belum menerima konfirmasi, hubungi <strong>support@sadaya.id</strong>
            </div>
        </t>
    </template>

</odoo>
