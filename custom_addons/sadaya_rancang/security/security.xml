<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Groups -->
        <record id="group_rancang_user" model="res.groups">
            <field name="name">Unit Kerja / Pemohon</field>
        </record>

        <record id="group_rancang_manajemen" model="res.groups">
            <field name="name">Manajemen</field>
            <field name="implied_ids" eval="[(4, ref('group_rancang_user'))]"/>
        </record>

        <record id="group_rancang_ppk" model="res.groups">
            <field name="name">PPK</field>
        </record>

        <record id="group_rancang_tim_teknis" model="res.groups">
            <field name="name">Tim Teknis</field>
        </record>
    </data>

    <data noupdate="0">
        <!-- Record Rules -->
        <!-- User hanya melihat usulannya sendiri -->
        <record id="rule_usulan_user_only" model="ir.rule">
            <field name="name">Usulan: Hanya Milik Sendiri (User)</field>
            <field name="model_id" ref="model_rancang_usulan"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_rancang_user'))]"/>
        </record>

        <!-- Manajemen melihat semua usulan -->
        <record id="rule_usulan_manajemen_all" model="ir.rule">
            <field name="name">Usulan: Semua (Manajemen)</field>
            <field name="model_id" ref="model_rancang_usulan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_rancang_manajemen'))]"/>
        </record>

        <!-- PPK melihat usulan yang disetujui -->
        <record id="rule_usulan_ppk_approved" model="ir.rule">
            <field name="name">Usulan: Disetujui (PPK)</field>
            <field name="model_id" ref="model_rancang_usulan"/>
            <field name="domain_force">[('state', 'in', ('approved', 'published'))]</field>
            <field name="groups" eval="[(4, ref('group_rancang_ppk'))]"/>
        </record>

        <!-- Tim Teknis hanya melihat HPS miliknya -->
        <record id="rule_hps_tim_teknis" model="ir.rule">
            <field name="name">HPS: Tugas Sendiri (Tim Teknis)</field>
            <field name="model_id" ref="model_rancang_hps"/>
            <field name="domain_force">[('tim_teknis_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_rancang_tim_teknis'))]"/>
        </record>
        
        <!-- PPK melihat semua HPS -->
        <record id="rule_hps_ppk_all" model="ir.rule">
            <field name="name">HPS: Semua (PPK)</field>
            <field name="model_id" ref="model_rancang_hps"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_rancang_ppk'))]"/>
        </record>
    </data>
</odoo>
