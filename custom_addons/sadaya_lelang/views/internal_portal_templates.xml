<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="internal_dashboard" name="Sadaya Lelang Internal Dashboard">
    <t t-call="website.layout">
      <t t-set="title">Sadaya Lelang Internal</t>
      <div id="wrap" class="o_sadaya_frontend sl-app-shell">
        <header class="sl-app-header">
          <div class="container sl-app-header__inner">
            <div>
              <p class="sl-app-eyebrow">Sistem Informasi Lelang</p>
              <a href="/sadaya-lelang/internal" class="sl-app-brand">Sadaya Lelang (Internal)</a>
            </div>
            <nav class="sl-app-nav" aria-label="Navigasi utama">
              <a href="/sadaya-lelang/internal" t-att-class="'active' if active_page == 'dashboard' else ''">Dashboard</a>
              <a href="/sadaya-lelang/internal/paket" t-att-class="'active' if active_page == 'paket' else ''">Kelola Paket</a>
            </nav>
          </div>
        </header>

        <section class="sl-hero">
          <div class="container">
            <div class="sl-hero__inner">
              <div>
                <p class="sl-kicker">Portal Operasional POKJA/PPK</p>
                <h1>Sadaya Lelang</h1>
                <p class="sl-lead">
                  Dashboard untuk mengelola workflow, evaluasi, dan dokumen paket lelang.
                </p>
                <div class="sl-hero__stats">
                  <div>
                    <span>Total Paket</span>
                    <strong><t t-esc="total_paket"/></strong>
                  </div>
                  <div>
                    <span>Paket Aktif</span>
                    <strong><t t-esc="paket_aktif"/></strong>
                  </div>
                  <div>
                    <span>Paket Draft</span>
                    <strong><t t-esc="paket_draft"/></strong>
                  </div>
                </div>
              </div>
              <div class="sl-hero__actions">
                <a href="/sadaya-lelang/internal/paket" class="btn btn-primary">Kelola Paket</a>
              </div>
            </div>
          </div>
        </section>

        <section class="sl-section">
          <div class="container">
            <div class="row g-3 sl-metrics">
              <div class="col-12 col-md-3">
                <article class="sl-card sl-card--metric">
                  <span>Total Paket</span>
                  <strong><t t-esc="total_paket"/></strong>
                </article>
              </div>
              <div class="col-12 col-md-3">
                <article class="sl-card sl-card--metric">
                  <span>Paket Aktif</span>
                  <strong><t t-esc="paket_aktif"/></strong>
                </article>
              </div>
              <div class="col-12 col-md-3">
                <article class="sl-card sl-card--metric">
                  <span>Paket Selesai</span>
                  <strong><t t-esc="paket_selesai"/></strong>
                </article>
              </div>
            </div>
          </div>
        </section>

        <section class="sl-section">
          <div class="container">
            <div class="sl-grid-header">
              <div>
                <h2>Status Paket</h2>
                <p>Ringkasan distribusi status tender lelang.</p>
              </div>
            </div>
            <div class="sl-pill-row">
              <t t-foreach="paket_breakdown" t-as="item">
                <span class="sl-pill">
                  <t t-esc="item['label']"/> <strong><t t-esc="item['count']"/></strong>
                </span>
              </t>
              <t t-if="not paket_breakdown">
                <span class="sl-empty">Belum ada data paket.</span>
              </t>
            </div>
          </div>
        </section>

        <section class="sl-section">
          <div class="container">
            <div class="sl-grid-header">
              <div>
                <h2>Paket Terbaru</h2>
                <p>Data terakhir yang masuk ke sistem.</p>
              </div>
              <a href="/sadaya-lelang/internal/paket">Buka semua paket</a>
            </div>
            <div class="row g-3">
              <t t-foreach="recent_paket" t-as="paket">
                <div class="col-12 col-lg-6">
                  <article class="sl-card sl-card--detail">
                    <div class="sl-card__top">
                      <div>
                        <span class="sl-label"><t t-esc="paket['status_label']"/></span>
                        <h3><t t-esc="paket['name']"/></h3>
                      </div>
                      <strong><t t-esc="paket['hps']"/></strong>
                    </div>
                    <dl class="sl-dl">
                      <div><dt>Kode Tender</dt><dd><t t-esc="paket['kode_tender']"/></dd></div>
                      <div><dt>Metode</dt><dd><t t-esc="paket['metode_pemilihan']"/></dd></div>
                    </dl>
                  </article>
                </div>
              </t>
              <t t-if="not recent_paket">
                <div class="col-12">
                  <div class="sl-card sl-empty-card">Belum ada paket yang tersimpan.</div>
                </div>
              </t>
            </div>
          </div>
        </section>
      </div>
    </t>
  </template>

  <template id="internal_paket_list" name="Sadaya Lelang Internal Paket List">
    <t t-call="website.layout">
      <t t-set="title">Daftar Paket Lelang (Internal)</t>
      <div id="wrap" class="o_sadaya_frontend sl-app-shell">
        <header class="sl-app-header">
          <div class="container sl-app-header__inner">
            <div>
              <p class="sl-app-eyebrow">Sistem Informasi Lelang</p>
              <a href="/sadaya-lelang/internal" class="sl-app-brand">Sadaya Lelang (Internal)</a>
            </div>
            <nav class="sl-app-nav" aria-label="Navigasi utama">
              <a href="/sadaya-lelang/internal">Dashboard</a>
              <a href="/sadaya-lelang/internal/paket" class="active">Kelola Paket</a>
            </nav>
          </div>
        </header>

        <section class="sl-page-header">
          <div class="container">
            <p class="sl-kicker">Portal Operasional POKJA/PPK</p>
            <h1>Daftar Paket Lelang</h1>
            <p class="sl-lead">Total paket: <t t-esc="total_paket"/></p>
          </div>
        </section>

        <section class="sl-section sl-section--form">
          <div class="container">
            <t t-if="notice_success">
              <div class="alert alert-success sl-notice" role="alert">
                <t t-esc="notice_success"/>
              </div>
            </t>
            <t t-if="notice_error">
              <div class="alert alert-danger sl-notice" role="alert">
                <t t-esc="notice_error"/>
              </div>
            </t>
          </div>
        </section>

        <section class="sl-section">
          <div class="container">
            <div class="row g-3">
              <t t-foreach="paket_cards" t-as="paket">
                <div class="col-12 col-lg-6">
                  <article class="sl-card sl-card--detail">
                    <div class="sl-card__top">
                      <div>
                        <span class="sl-label"><t t-esc="paket['status_label']"/></span>
                        <h3><t t-esc="paket['name']"/></h3>
                      </div>
                      <strong><t t-esc="paket['hps']"/></strong>
                    </div>
                    <dl class="sl-dl">
                      <div><dt>Kode Tender</dt><dd><t t-esc="paket['kode_tender']"/></dd></div>
                      <div><dt>Metode</dt><dd><t t-esc="paket['metode_pemilihan']"/></dd></div>
                    </dl>
                    <div class="sl-actions" style="margin-top: 16px;">
                      <a t-attf-href="/sadaya-lelang/internal/paket/{{ paket['id'] }}" class="btn btn-sm btn-primary">Kelola Detail &amp; Evaluasi</a>
                    </div>
                  </article>
                </div>
              </t>
              <t t-if="not paket_cards">
                <div class="col-12">
                  <div class="sl-card sl-empty-card">Belum ada paket yang tersimpan.</div>
                </div>
              </t>
            </div>
          </div>
        </section>
      </div>
    </t>
  </template>

  <template id="internal_paket_detail" name="Sadaya Lelang Internal Paket Detail">
    <t t-call="website.layout">
      <t t-set="title">Kelola Detail Paket (Internal)</t>
      <div id="wrap" class="o_sadaya_frontend sl-app-shell">
        <header class="sl-app-header">
          <div class="container sl-app-header__inner">
            <div>
              <p class="sl-app-eyebrow">Sistem Informasi Lelang</p>
              <a href="/sadaya-lelang/internal" class="sl-app-brand">Sadaya Lelang (Internal)</a>
            </div>
            <nav class="sl-app-nav" aria-label="Navigasi utama">
              <a href="/sadaya-lelang/internal">Dashboard</a>
              <a href="/sadaya-lelang/internal/paket" class="active">Kelola Paket</a>
            </nav>
          </div>
        </header>

        <section class="sl-page-header">
          <div class="container">
            <a href="/sadaya-lelang/internal/paket" class="btn btn-sm btn-outline-secondary mb-3">&amp;larr; Kembali ke Daftar</a>
            <p class="sl-kicker">Workspace Paket Lelang</p>
            <h1><t t-esc="paket.name"/></h1>
            <p class="sl-lead">Kode: <t t-esc="paket.kode_tender or '-'"/></p>
          </div>
        </section>

        <section class="sl-section sl-section--form">
          <div class="container">
            <t t-if="notice_success">
              <div class="alert alert-success sl-notice" role="alert">
                <t t-esc="notice_success"/>
              </div>
            </t>
            <t t-if="notice_error">
              <div class="alert alert-danger sl-notice" role="alert">
                <t t-esc="notice_error"/>
              </div>
            </t>
            
            <div class="sl-card" style="padding: 24px;">
              <div class="sl-card__top">
                <h3>Informasi Paket</h3>
                <span class="sl-label"><t t-esc="status_label"/></span>
              </div>
              <div class="sl-actions" t-if="actions">
                <t t-foreach="actions" t-as="action">
                  <form t-attf-action="/sadaya-lelang/internal/paket/{{ paket.id }}/workflow" method="post" style="display:inline-block; margin-right:8px; margin-bottom:8px;">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="action" t-att-value="action['key']"/>
                    <button type="submit" t-att-class="'btn btn-sm ' + action['class']">
                      <t t-esc="action['label']"/>
                    </button>
                  </form>
                </t>
              </div>
            </div>

            <!-- Bagian Penawaran & Evaluasi -->
            <div class="sl-card" style="margin-top: 24px; padding: 24px;">
              <div class="sl-card__top">
                <h3>Evaluasi Penawaran Vendor</h3>
              </div>
              <t t-if="penawaran_rows">
                <div class="sl-penawaran-list">
                  <t t-foreach="penawaran_rows" t-as="row">
                    <article class="sl-penawaran-item" style="border: 1px solid #e2e8f0; border-radius: 8px; padding: 16px; margin-bottom: 16px;">
                      <div class="sl-penawaran-head" style="display:flex; justify-content:space-between; margin-bottom:12px;">
                        <strong><t t-esc="row['vendor']"/></strong>
                        <span style="font-weight:bold; color:#0f172a;"><t t-esc="row['harga_penawaran']"/></span>
                      </div>
                      <p class="sl-penawaran-meta">Status Penawaran: <t t-esc="row['status']"/></p>

                      <form class="sl-form" t-attf-action="/sadaya-lelang/internal/penawaran/{{ row['id'] }}/evaluate" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="row g-2 align-items-end">
                          <div class="col-12 col-md-3">
                            <label class="sl-field-label" style="font-size:0.875rem;">Eval Administrasi</label>
                            <select class="form-select sl-input form-select-sm" name="eval_administrasi">
                              <option value="">(Belum Diperiksa)</option>
                              <t t-foreach="evaluasi_options" t-as="opt">
                                <option t-att-value="opt['value']" t-att-selected="opt['value'] == row['eval_administrasi'] and 'selected' or None">
                                  <t t-esc="opt['label']"/>
                                </option>
                              </t>
                            </select>
                          </div>
                          <div class="col-12 col-md-2">
                            <label class="sl-field-label" style="font-size:0.875rem;">Skor Teknis</label>
                            <input type="number" class="form-control sl-input form-control-sm" name="skor_teknis" step="0.01" t-att-value="row['skor_teknis']"/>
                          </div>
                          <div class="col-12 col-md-2">
                            <label class="sl-field-label" style="font-size:0.875rem;">Skor Harga</label>
                            <input type="number" class="form-control sl-input form-control-sm" name="skor_harga" step="0.01" t-att-value="row['skor_harga']"/>
                          </div>
                          <div class="col-12 col-md-2">
                            <label class="sl-field-label" style="font-size:0.875rem;">Eval Kualifikasi</label>
                            <select class="form-select sl-input form-select-sm" name="eval_kualifikasi">
                              <option value="">(Belum Diperiksa)</option>
                              <t t-foreach="evaluasi_kual_options" t-as="opt">
                                <option t-att-value="opt['value']" t-att-selected="opt['value'] == row['eval_kualifikasi'] and 'selected' or None">
                                  <t t-esc="opt['label']"/>
                                </option>
                              </t>
                            </select>
                          </div>
                          <div class="col-12 col-md-2">
                            <label class="sl-field-label" style="font-size:0.875rem;">Harga Wajar?</label>
                            <div>
                               <input type="checkbox" name="eval_harga_wajar" t-att-checked="row['eval_harga_wajar'] == 'Ya' and 'checked' or None"/> Ya
                            </div>
                          </div>
                          <div class="col-12 col-md-1">
                            <button type="submit" class="btn btn-sm btn-outline-primary" style="width:100%">Simpan</button>
                          </div>
                        </div>
                      </form>
                    </article>
                  </t>
                </div>
              </t>
              <t t-if="not penawaran_rows">
                <p>Belum ada vendor yang memasukkan dokumen penawaran.</p>
              </t>
            </div>

            <!-- Bagian Upload Dokumen -->
            <div class="sl-card" style="margin-top: 24px; padding: 24px;">
              <div class="sl-card__top">
                <h3>Upload Dokumen POKJA (BA Aanwijzing, Addendum, dll)</h3>
              </div>
              <form class="sl-form" t-attf-action="/sadaya-lelang/internal/paket/{{ paket.id }}/upload_dokumen" method="post" enctype="multipart/form-data">
                 <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                 <div class="row g-2">
                    <div class="col-12 col-md-4">
                       <label class="sl-field-label">Nama Dokumen</label>
                       <input type="text" class="form-control sl-input" name="name" required="required" placeholder="Contoh: BA Aanwijzing"/>
                    </div>
                    <div class="col-12 col-md-4">
                       <label class="sl-field-label">Deskripsi</label>
                       <input type="text" class="form-control sl-input" name="description"/>
                    </div>
                    <div class="col-12 col-md-4">
                       <label class="sl-field-label">File PDF/Word</label>
                       <input type="file" class="form-control" name="file_dokumen" required="required"/>
                    </div>
                    <div class="col-12 mt-3">
                       <button type="submit" class="btn btn-dark">Unggah Dokumen</button>
                    </div>
                 </div>
              </form>

              <div style="margin-top:24px;">
                <h4>Daftar Dokumen Saat Ini</h4>
                <ul>
                  <t t-foreach="paket.dokumen_ids" t-as="doc">
                    <li><strong><t t-esc="doc.name"/></strong> - <t t-esc="doc.file_name"/></li>
                  </t>
                </ul>
              </div>
            </div>

          </div>
        </section>

      </div>
    </t>
  </template>
</odoo>
