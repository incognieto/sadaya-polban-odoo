<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sadaya Lelang Paket Tree View -->
    <record id="view_sadaya_lelang_paket_tree" model="ir.ui.view">
        <field name="name">sadaya_lelang.paket.tree</field>
        <field name="model">sadaya_lelang.paket</field>
        <field name="arch" type="xml">
            <list string="Daftar Paket Lelang">
                <field name="kode_tender"/>
                <field name="name"/>
                <field name="metode_pemilihan"/>
                <field name="hps" widget="monetary"/>
                <field name="status"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Sadaya Lelang Paket Form View -->
    <record id="view_sadaya_lelang_paket_form" model="ir.ui.view">
        <field name="name">sadaya_lelang.paket.form</field>
        <field name="model">sadaya_lelang.paket</field>
        <field name="arch" type="xml">
            <form string="Paket Lelang">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="persiapan_lelang,pengumuman_lelang,pendaftaran_penawaran,evaluasi_pembuktian,laporan_hasil,sppbj,kontrak,pelaksanaan,bast,selesai"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="kode_tender"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="metode_pemilihan"/>
                            <field name="hps" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Aktor Terlibat">
                            <field name="user_id"/>
                            <field name="manajemen_id"/>
                            <field name="ppk_id"/>
                            <field name="pokja_id"/>
                            <field name="pphp_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Deskripsi">
                            <field name="description"/>
                        </page>
                        <page string="Jadwal Lelang">
                            <field name="jadwal_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="perubahan"/>
                                </list>
                            </field>
                        </page>
                        <page string="Dokumen Pengadaan &amp; Hasil">
                            <group>
                                <group string="Fase Persiapan">
                                    <field name="file_kebutuhan"/>
                                    <field name="file_disposisi"/>
                                </group>
                                <group string="Fase Penetapan">
                                    <field name="file_sppbj"/>
                                    <field name="file_jaminan_pelaksanaan"/>
                                    <field name="file_kontrak"/>
                                </group>
                                <group string="Fase Serah Terima">
                                    <field name="file_bast"/>
                                </group>
                            </group>
                        </page>
                        <page string="Dokumen Lelang (POKJA)">
                            <field name="dokumen_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="file_name" invisible="1"/>
                                    <field name="file_dokumen" filename="file_name"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Penawaran Vendor">
                            <field name="penawaran_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="vendor_id"/>
                                    <field name="harga_penawaran" widget="monetary"/>
                                    <field name="status"/>
                                    <field name="skor_teknis"/>
                                    <field name="skor_harga"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Penawaran Form View -->
    <record id="view_sadaya_lelang_penawaran_form" model="ir.ui.view">
        <field name="name">sadaya_lelang.penawaran.form</field>
        <field name="model">sadaya_lelang.penawaran</field>
        <field name="arch" type="xml">
            <form string="Dokumen Penawaran">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="paket_id" readonly="1"/>
                            <field name="vendor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="harga_penawaran" widget="monetary" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="file_kualifikasi" readonly="1"/>
                            <field name="file_penawaran" readonly="1"/>
                        </group>
                    </group>
                    <group string="Evaluasi Pokja" groups="sadaya_lelang.group_lelang_pokja">
                        <field name="skor_teknis"/>
                        <field name="skor_harga"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_sadaya_lelang_paket" model="ir.actions.act_window">
        <field name="name">Paket Lelang</field>
        <field name="res_model">sadaya_lelang.paket</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_sadaya_lelang_penawaran" model="ir.actions.act_window">
        <field name="name">Semua Penawaran</field>
        <field name="res_model">sadaya_lelang.penawaran</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
