<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sadaya Lelang Paket Tree View -->
    <record id="view_sadaya_lelang_paket_tree" model="ir.ui.view">
        <field name="name">sadaya_lelang.paket.tree</field>
        <field name="model">sadaya_lelang.paket</field>
        <field name="arch" type="xml">
            <list string="Daftar Paket Lelang">
                <field name="kode_tender"/>
                <field name="name"/>
                <field name="metode_pemilihan"/>
                <field name="hps" widget="monetary"/>
                <field name="status"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Sadaya Lelang Paket Form View -->
    <record id="view_sadaya_lelang_paket_form" model="ir.ui.view">
        <field name="name">sadaya_lelang.paket.form</field>
        <field name="model">sadaya_lelang.paket</field>
        <field name="arch" type="xml">
            <form string="Paket Lelang">
                <header>
                    <button name="action_to_pengumuman" string="Mulai Pengumuman" type="object" class="oe_highlight" invisible="status != 'draft'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_to_pendaftaran" string="Buka Pendaftaran" type="object" class="oe_highlight" invisible="status != 'pengumuman'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_to_penjelasan" string="Mulai Pemberian Penjelasan" type="object" class="oe_highlight" invisible="status != 'pendaftaran'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_to_pemasukan" string="Mulai Pemasukan Penawaran" type="object" class="oe_highlight" invisible="status != 'penjelasan'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_to_pembukaan" string="Mulai Pembukaan" type="object" class="oe_highlight" invisible="status != 'pemasukan_penawaran'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_mulai_evaluasi" string="Mulai Evaluasi" type="object" class="oe_highlight" invisible="status != 'pembukaan'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_tetapkan_pemenang" string="Tetapkan Pemenang" type="object" class="oe_highlight" invisible="status not in ['eval_administrasi', 'eval_teknis', 'eval_harga', 'pembuktian_kualifikasi']" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_to_masa_sanggah" string="Mulai Masa Sanggah" type="object" class="oe_highlight" invisible="status != 'penetapan_pemenang'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_evaluasi_ulang" string="Evaluasi Ulang (Terima Sanggah)" type="object" class="btn-danger" invisible="status not in ['penetapan_pemenang', 'masa_sanggah']" groups="sadaya_lelang.group_lelang_pokja" confirm="Yakin ingin mengulang evaluasi? Ini akan mengembalikan status ke Pembuktian Kualifikasi."/>
                    <button name="action_to_sppbj" string="Terbitkan SPPBJ" type="object" class="oe_highlight" invisible="status != 'masa_sanggah'" groups="sadaya_lelang.group_lelang_ppk"/>
                    <button name="action_to_pam" string="Adakan PAM" type="object" class="oe_highlight" invisible="status != 'sppbj'" groups="sadaya_lelang.group_lelang_ppk"/>
                    <button name="action_to_kontrak" string="Tanda Tangan Kontrak" type="object" class="oe_highlight" invisible="status != 'pam'" groups="sadaya_lelang.group_lelang_ppk"/>
                    <button name="action_to_pelaksanaan" string="Mulai Pelaksanaan" type="object" class="oe_highlight" invisible="status != 'kontrak'" groups="sadaya_lelang.group_lelang_ppk"/>
                    <button name="action_to_selesai" string="Selesaikan Tender" type="object" class="oe_highlight" invisible="status != 'pelaksanaan'" groups="sadaya_lelang.group_lelang_pphp" confirm="Apakah laporan PPHP dan BAST sudah lengkap dan sesuai? Tender akan ditutup."/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,pengumuman,penjelasan,pemasukan_penawaran,eval_administrasi,penetapan_pemenang,masa_sanggah,kontrak,pelaksanaan,selesai"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="kode_tender"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="metode_pemilihan"/>
                            <field name="hps" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Aktor Terlibat">
                            <field name="user_id"/>
                            <field name="manajemen_id"/>
                            <field name="ppk_id"/>
                            <field name="pokja_id"/>
                            <field name="pphp_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Deskripsi">
                            <field name="description"/>
                        </page>
                        <page string="Jadwal Lelang">
                            <field name="jadwal_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="perubahan"/>
                                </list>
                            </field>
                        </page>
                        <page string="Dokumen Pengadaan &amp; Hasil">
                            <group>
                                <group string="Fase Persiapan">
                                    <field name="file_kebutuhan"/>
                                    <field name="file_disposisi"/>
                                </group>
                                <group string="Fase Penetapan">
                                    <field name="file_sppbj_name" invisible="1"/>
                                    <field name="file_sppbj" filename="file_sppbj_name"/>
                                </group>
                                <group string="Fase Kontrak &amp; Pelaksanaan">
                                    <field name="file_draft_kontrak_name" invisible="1"/>
                                    <field name="file_draft_kontrak" filename="file_draft_kontrak_name"/>
                                    <field name="file_kontrak_name" invisible="1"/>
                                    <field name="file_kontrak" filename="file_kontrak_name"/>
                                    <field name="file_jaminan_pelaksanaan_name" invisible="1"/>
                                    <field name="file_jaminan_pelaksanaan" filename="file_jaminan_pelaksanaan_name"/>
                                </group>
                                <group string="Fase Serah Terima">
                                    <field name="file_laporan_pphp_name" invisible="1"/>
                                    <field name="file_laporan_pphp" filename="file_laporan_pphp_name"/>
                                    <field name="file_bast_name" invisible="1"/>
                                    <field name="file_bast" filename="file_bast_name"/>
                                </group>
                            </group>
                        </page>
                        <page string="Dokumen Lelang (POKJA)">
                            <group>
                                <field name="file_dokumen_pemilihan_name" invisible="1"/>
                                <field name="file_dokumen_pemilihan" filename="file_dokumen_pemilihan_name"/>
                                <field name="file_ba_penjelasan_name" invisible="1"/>
                                <field name="file_ba_penjelasan" filename="file_ba_penjelasan_name"/>
                                <field name="file_bahp_name" invisible="1"/>
                                <field name="file_bahp" filename="file_bahp_name"/>
                            </group>
                            <separator string="Dokumen Lainnya"/>
                            <field name="dokumen_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="file_name" invisible="1"/>
                                    <field name="file_dokumen" filename="file_name"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Forum Tanya Jawab" invisible="status in ['draft', 'menunggu_persetujuan', 'pengumuman', 'pendaftaran']">
                            <field name="penjelasan_ids">
                                <list editable="bottom" decoration-info="status_penjelasan == 'masuk'">
                                    <field name="vendor_id"/>
                                    <field name="pertanyaan"/>
                                    <field name="jawaban_pokja"/>
                                    <field name="status_penjelasan"/>
                                </list>
                            </field>
                        </page>
                        <page string="Masa Sanggah" invisible="status not in ['masa_sanggah', 'sppbj', 'pam', 'kontrak', 'pelaksanaan', 'selesai']">
                            <field name="sanggah_ids">
                                <list editable="bottom" decoration-danger="status_sanggah == 'masuk'" decoration-success="status_sanggah == 'diterima'">
                                    <field name="vendor_id"/>
                                    <field name="pertanyaan"/>
                                    <field name="jawaban_pokja"/>
                                    <field name="status_sanggah"/>
                                </list>
                            </field>
                        </page>
                        <page string="Penawaran Vendor">
                            <field name="penawaran_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="vendor_id"/>
                                    <field name="harga_penawaran" widget="monetary"/>
                                    <field name="status"/>
                                    <field name="skor_teknis"/>
                                    <field name="skor_harga"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Penawaran Form View -->
    <record id="view_sadaya_lelang_penawaran_form" model="ir.ui.view">
        <field name="name">sadaya_lelang.penawaran.form</field>
        <field name="model">sadaya_lelang.penawaran</field>
        <field name="arch" type="xml">
            <form string="Dokumen Penawaran">
                <header>
                    <button name="action_set_pemenang" type="object" string="Tetapkan Pemenang" class="oe_highlight" invisible="status == 'winner'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <button name="action_set_gagal" type="object" string="Gugurkan" invisible="status == 'failed'" groups="sadaya_lelang.group_lelang_pokja"/>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="paket_id" readonly="1"/>
                            <field name="vendor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="harga_penawaran" widget="monetary" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="file_kualifikasi" readonly="1"/>
                            <field name="file_penawaran" readonly="1"/>
                        </group>
                    </group>
                    <group string="Evaluasi Pokja" groups="sadaya_lelang.group_lelang_pokja">
                        <group string="Administrasi &amp; Teknis">
                            <field name="eval_administrasi" widget="radio" options="{'horizontal': true}"/>
                            <field name="skor_teknis" invisible="eval_administrasi != 'lulus'"/>
                        </group>
                        <group string="Harga &amp; Kualifikasi">
                            <field name="skor_harga" invisible="eval_administrasi != 'lulus'"/>
                            <field name="eval_harga_wajar" invisible="eval_administrasi != 'lulus'"/>
                            <field name="eval_kualifikasi" widget="radio" options="{'horizontal': true}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_sadaya_lelang_paket" model="ir.actions.act_window">
        <field name="name">Paket Lelang</field>
        <field name="res_model">sadaya_lelang.paket</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_sadaya_lelang_penawaran" model="ir.actions.act_window">
        <field name="name">Semua Penawaran</field>
        <field name="res_model">sadaya_lelang.penawaran</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
