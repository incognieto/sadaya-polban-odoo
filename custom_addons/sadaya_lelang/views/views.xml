<odoo>
  <data>
    <record model="ir.ui.view" id="sadaya_lelang.list">
      <field name="name">sadaya_lelang list</field>
      <field name="model">sadaya_lelang.sadaya_lelang</field>
      <field name="arch" type="xml">
        <list>
          <field name="kode"/>
          <field name="nama"/>
          <field name="tahap"/>
        </list>
      </field>
    </record>

    <record model="ir.actions.act_window" id="sadaya_lelang.action_window">
      <field name="name">sadaya_lelang window</field>
      <field name="res_model">sadaya_lelang.sadaya_lelang</field>
      <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.server" id="sadaya_lelang.action_server">
      <field name="name">sadaya_lelang servers</field>
      <field name="model_id" ref="model_sadaya_lelang_sadaya_lelang"/>
      <field name="state">code</field>
      <field name="code">
        action = {
          "type": "ir.actions.act_window",   # jenis action
          "view_mode": "list,form",          # view yang diminta
          "res_model": "sadaya_lelang.sadaya_lelang",       # model saat ini
          "name": "sadaya_lelang servers",
        } 
      </field>
    </record>

    <menuitem name="sadaya_lelang" id="sadaya_lelang.menu_root"/>

    <menuitem name="Menu 1"
              id="sadaya_lelang.menu_1"
              parent="sadaya_lelang.menu_root"/>
    <menuitem name="Menu 2"
              id="sadaya_lelang.menu_2"
              parent="sadaya_lelang.menu_root"/>

    <menuitem name="List"
              id="sadaya_lelang.menu_1_list"
              parent="sadaya_lelang.menu_1"
              action="sadaya_lelang.action_window"/>
    <menuitem name="Server to list"
              id="sadaya_lelang.menu_server_list"
              parent="sadaya_lelang.menu_2"
              action="sadaya_lelang.action_server"/>

  </data>
</odoo>

