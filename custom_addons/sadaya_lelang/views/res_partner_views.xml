<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Res Partner View -->
    <record id="view_partner_form_tender" model="ir.ui.view">
        <field name="name">res.partner.form.sadaya_lelang</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Data Vendor SPSE" invisible="is_vendor_tender == False">
                    <group>
                        <group>
                            <field name="vendor_status" widget="badge" decoration-success="vendor_status == 'verified'" decoration-warning="vendor_status == 'waiting'" decoration-info="vendor_status == 'draft'" decoration-danger="vendor_status == 'rejected'"/>
                            <field name="is_vendor_tender"/>
                        </group>
                        <group string="Dokumen Legalitas">
                            <field name="nib_number"/>
                            <field name="file_nib_name" invisible="1"/>
                            <field name="file_nib" filename="file_nib_name"/>
                            
                            <field name="npwp_number"/>
                            <field name="file_npwp_name" invisible="1"/>
                            <field name="file_npwp" filename="file_npwp_name"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Action for Vendor Verification -->
    <record id="action_vendor_verification" model="ir.actions.act_window">
        <field name="name">Verifikasi Vendor</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_vendor_tender', '=', True)]</field>
        <field name="context">{'default_is_vendor_tender': True}</field>
    </record>
</odoo>
