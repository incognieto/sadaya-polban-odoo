<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================== -->
    <!-- 0. TEMPLATE LAYOUT SIDEBAR UTAMA           -->
    <!-- ========================================== -->
    <template id="portal_sidebar_layout" name="Portal Sidebar Lelang">
        <t t-call="website.layout">
            <div id="wrap" class="bg-light pb-5" style="min-height: 100vh;">
                <div class="container-fluid pt-4 px-4">
                    <div class="row">
                        <!-- SIDEBAR MENU KIRI -->
                        <div class="col-md-2 mb-4">
                            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 20px;">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-4 p-2">
                                        <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                            <i class="fa fa-building"/>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold text-truncate" style="max-width: 120px;"><t t-esc="env.user.name"/></h6>
                                            <small class="text-muted">Vendor SPSE</small>
                                        </div>
                                    </div>
                                    <p class="text-muted small fw-bold mb-2 px-2">MENU LELANG</p>
                                    <div class="list-group list-group-flush border-0">
                                        <a href="/tender-portal/dashboard" 
                                           t-attf-class="list-group-item list-group-item-action border-0 rounded mb-2 #{'active bg-primary bg-opacity-25 text-primary fw-bold' if active_menu == 'dashboard' else 'text-secondary'}">
                                            <i class="fa fa-th-large me-2"></i> Dashboard
                                        </a>
                                        <a href="/tender-portal/tenders" 
                                           t-attf-class="list-group-item list-group-item-action border-0 rounded mb-2 #{'active bg-primary bg-opacity-25 text-primary fw-bold' if active_menu == 'tender' else 'text-secondary'}">
                                            <i class="fa fa-gavel me-2"></i> Info Lelang
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- KONTEN UTAMA KANAN -->
                        <div class="col-md-10">
                            <t t-out="0"/>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Public Tender List -->
    <template id="portal_tender_list" name="Daftar Tender SPSE">
        <t t-call="sadaya_lelang.portal_sidebar_layout">
            <t t-set="active_menu" t-value="'tender'"/>
            <div class="mb-4">
                <h4 class="fw-bold mb-1">Sadaya Lelang</h4>
                <p class="text-muted small">Daftar Paket Tender / Seleksi</p>
            </div>
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light text-secondary text-center small">
                                <tr>
                                    <th>Kode</th>
                                    <th>Nama Paket</th>
                                    <th>HPS</th>
                                    <th>Status</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="tenders" t-as="tender">
                                    <tr class="text-center">
                                        <td><t t-esc="tender.kode_tender"/></td>
                                        <td class="text-start fw-bold"><t t-esc="tender.name"/></td>
                                        <td class="text-end fw-semibold text-primary"><t t-esc="tender.hps" t-options="{'widget': 'monetary', 'display_currency': tender.currency_id}"/></td>
                                        <td><span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3"><t t-esc="tender.status"/></span></td>
                                        <td>
                                            <a t-attf-href="/tenders/#{tender.id}" class="btn btn-sm btn-outline-primary rounded-pill px-3">Detail</a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Tender Detail -->
    <template id="portal_tender_detail" name="Detail Tender">
        <t t-call="sadaya_lelang.portal_sidebar_layout">
            <t t-set="active_menu" t-value="'tender'"/>
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold text-primary mb-3"><t t-esc="tender.name"/></h3>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <strong>Kode Tender:</strong> <t t-esc="tender.kode_tender"/><br/>
                            <strong>Metode:</strong> <t t-esc="tender.metode_pemilihan"/><br/>
                            <strong>HPS:</strong> <t t-esc="tender.hps" t-options="{'widget': 'monetary', 'display_currency': tender.currency_id}"/><br/>
                        </div>
                        <div class="col-md-6">
                            <strong>Status:</strong> <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3"><t t-esc="tender.status"/></span>
                        </div>
                    </div>
                    
                    <hr/>
                    <h5 class="fw-bold mb-3">Jadwal Tahapan</h5>
                    <table class="table table-sm align-middle">
                        <thead class="table-light small">
                            <tr>
                                <th>Tahapan</th>
                                <th>Mulai</th>
                                <th>Selesai</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="tender.jadwal_ids" t-as="jadwal">
                                <tr>
                                    <td><t t-esc="jadwal.name"/></td>
                                    <td><t t-esc="jadwal.start_date"/></td>
                                    <td><t t-esc="jadwal.end_date"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    
                    <div t-if="request.env.user.id != request.env.ref('base.public_user').id" class="mt-4">
                        <a href="/tender-portal/dashboard" class="btn btn-primary rounded-pill px-4 fw-bold">Masuk Dashboard Penawaran</a>
                    </div>
                    <div t-else="" class="mt-4">
                        <p class="text-danger small"><i class="fa fa-lock me-1"></i> Silahkan <a href="/web/login">Login</a> untuk mengikuti lelang ini.</p>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
    <!-- My Tenders Dashboard -->
    <template id="portal_my_tenders" name="Dashboard Vendor">
        <t t-call="sadaya_lelang.portal_sidebar_layout">
            <t t-set="active_menu" t-value="'dashboard'"/>
            <div class="mb-4">
                <h4 class="fw-bold mb-1">Riwayat Penawaran Lelang</h4>
            </div>
            
            <div t-if="partner.vendor_status != 'verified'" class="alert alert-warning border-0 rounded-4">
                <i class="fa fa-exclamation-triangle me-2"></i> <strong>Perhatian!</strong> Status verifikasi Anda saat ini: <b><t t-esc="partner.vendor_status"/></b>. Anda belum bisa mengajukan penawaran.
            </div>
            
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <table class="table align-middle">
                        <thead class="table-light text-secondary text-center small">
                            <tr>
                                <th>Tender</th>
                                <th>No Penawaran</th>
                                <th>Harga Penawaran</th>
                                <th>Status Evaluasi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="bids" t-as="bid">
                                <tr class="text-center">
                                    <td class="text-start fw-bold"><t t-esc="bid.paket_id.name"/></td>
                                    <td><t t-esc="bid.name"/></td>
                                    <td class="text-end fw-semibold"><t t-esc="bid.harga_penawaran" t-options="{'widget': 'monetary', 'display_currency': bid.currency_id}"/></td>
                                    <td><span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3"><t t-esc="bid.status"/></span></td>
                                </tr>
                            </t>
                            <tr t-if="not bids">
                                <td colspan="4" class="text-center py-4 text-muted">Belum ada penawaran yang diajukan.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </t>
    </template>
</odoo>
