<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_sadaya_lelang_paket" model="ir.sequence">
            <field name="name">Sadaya Lelang Kode Paket</field>
            <field name="code">sadaya_lelang.paket</field>
            <field name="prefix">PKT/LELANG/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_sadaya_lelang_penawaran" model="ir.sequence">
            <field name="name">Sadaya Lelang Nomor Penawaran</field>
            <field name="code">sadaya_lelang.penawaran</field>
            <field name="prefix">PNW/LELANG/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
