<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_sadaya_lelang" model="ir.module.category">
            <field name="name">Sadaya Lelang (SPSE)</field>
            <field name="description">Manajemen Lelang dan Pengadaan</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_lelang_user" model="res.groups">
            <field name="name">USER / Pemohon</field>
            <field name="category_id" ref="module_category_sadaya_lelang"/>
            <field name="comment">Akses untuk melihat paket yang diajukan.</field>
        </record>

        <record id="group_lelang_manajemen" model="res.groups">
            <field name="name">MANAJEMEN / Approver</field>
            <field name="category_id" ref="module_category_sadaya_lelang"/>
            <field name="comment">Akses untuk menyetujui anggaran.</field>
        </record>

        <record id="group_lelang_pphp" model="res.groups">
            <field name="name">PPHP</field>
            <field name="category_id" ref="module_category_sadaya_lelang"/>
            <field name="comment">Akses untuk menerima barang/jasa (BAST).</field>
        </record>

        <record id="group_lelang_pokja" model="res.groups">
            <field name="name">Pokja Pemilihan</field>
            <field name="category_id" ref="module_category_sadaya_lelang"/>
            <field name="comment">Akses untuk mengelola tahapan tender dan evaluasi penawaran.</field>
        </record>

        <record id="group_lelang_ppk" model="res.groups">
            <field name="name">Pejabat Pembuat Komitmen (PPK)</field>
            <field name="category_id" ref="module_category_sadaya_lelang"/>
            <field name="implied_ids" eval="[(4, ref('group_lelang_pokja'))]"/>
            <field name="comment">Akses penuh untuk pembuatan SPPBJ dan Kontrak.</field>
        </record>

        <!-- Record Rules -->
        <record id="rule_lelang_penawaran_vendor" model="ir.rule">
            <field name="name">Vendor hanya bisa melihat penawarannya sendiri</field>
            <field name="model_id" ref="model_sadaya_lelang_penawaran"/>
            <field name="domain_force">[('vendor_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="rule_lelang_penawaran_pokja" model="ir.rule">
            <field name="name">Pokja bisa melihat semua penawaran</field>
            <field name="model_id" ref="model_sadaya_lelang_penawaran"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_lelang_pokja'))]"/>
        </record>
    </data>
</odoo>
