<odoo>
  <data>

    <!-- ===================================================== -->
    <!-- 1️⃣ VIEW: Mendefinisikan tampilan LIST (table)         -->
    <!-- ===================================================== -->
    <!-- Ini hanya "template UI", tidak aktif sendiri -->
    <!-- Akan dipakai jika ada action yang meminta list view -->
    <record model="ir.ui.view" id="sadaya_tender.list">
      <!-- Nama internal view -->
      <field name="name">sadaya_tender list</field>

      <!-- Model yang digunakan view ini -->
      <!-- HARUS sama dengan res_model di action -->
      <field name="model">sadaya_tender.sadaya_tender</field>

      <!-- Definisi tampilan -->
      <field name="arch" type="xml">
        <!-- 'list' = tampilan tabel -->
        <list>
          <!-- Field yang ditampilkan sebagai kolom -->
          <field name="name"/>
          <field name="value"/>
          <field name="value2"/>
        </list>
      </field>
    </record>


    <!-- ===================================================== -->
    <!-- 2️⃣ ACTION: Entry point utama (ini jadi action=90)     -->
    <!-- ===================================================== -->
    <!-- Action ini yang akan dipanggil saat menu diklik -->
    <record model="ir.actions.act_window" id="sadaya_tender.action_window">

      <!-- Nama yang tampil di UI -->
      <field name="name">sadaya_tender window</field>

      <!-- Model yang akan dibuka -->
      <field name="res_model">sadaya_tender.sadaya_tender</field>

      <!-- Urutan view yang digunakan -->
      <!-- list dulu → lalu form -->
      <field name="view_mode">list,form</field>

      <!-- NOTE:
           Tidak ada view_id → Odoo akan AUTO cari view
           berdasarkan:
           - model = si_qut.si_qut
           - type = list
      -->
    </record>


    <!-- ===================================================== -->
    <!-- 3️⃣ SERVER ACTION: Action berbasis Python (dynamic)    -->
    <!-- ===================================================== -->
    <!-- Ini alternatif action yang dijalankan lewat code -->
    <record model="ir.actions.server" id="sadaya_tender.action_server">

      <field name="name">sadaya_tender servers</field>

      <!-- Model target -->
      <field name="model_id" ref="model_sadaya_tender_sadaya_tender"/>

      <!-- Mode: execute Python code -->
      <field name="state">code</field>

      <!--
        Lihat relasi antara isi dari field "state" dengan atribut name "code" dibawah. alurnya yang pertama 
        adalah ditanyakan dulu ini mau namanya apa, dengan berdasarkan atribut name (sbg contoh: name="name" untuk
        nama, name="model_id" untuk model yang digunakan (referensinya juga dalam bentuk format xml, jadi yang awal
        nya siqut.siqut jadi siqut_siqut dan tambahkan model_ didepannya)). jangan tambahkan komentar di antara
        blok yang berkaitan dengan kode program lain (misalkan python untuk field "code") karena bisa merusak 
        struktur python, yang menyebabkan xml tidak mengirimkan field "code" sama sekali karea sistem xml
        sangat ketat.
        -->
      <field name="code">
        action = {
          "type": "ir.actions.act_window",   # jenis action
          "view_mode": "list,form",          # view yang diminta
          "res_model": "sadaya_tender.sadaya_tender",       # model saat ini
          "name": "sadaya_tender servers",
        } 
      </field>
      <!-- mengapa nama yang digunakan adalah field "name" dalam "code", karena yang bertugas sebagai representasi
      visual bukanlah "actions.server", melainkan "act_window". "actions.server" hanya memperbolehkan eksekusi, akses
      database, dan sebagainya. selengkapnya di dokumentasi:
      https://www.odoo.com/documentation/19.0/id/developer/reference/backend/actions.html-->
    </record>


    <!-- ===================================================== -->
    <!-- 4️⃣ MENU ROOT (Parent Menu)                            -->
    <!-- ===================================================== -->
    <!-- Ini hanya container menu -->
    <menuitem name="sadaya_tender" id="sadaya_tender.menu_root"/>


    <!-- ===================================================== -->
    <!-- 5️⃣ SUB MENU (Kategori)                                -->
    <!-- ===================================================== -->
    <!-- Tidak menjalankan apa-apa, hanya grouping -->
    <menuitem name="Menu sisigma"
              id="sadaya_tender.menu_1"
              parent="sadaya_tender.menu_root"/>

    <menuitem name="Menu alpha"
              id="sadaya_tender.menu_2"
              parent="sadaya_tender.menu_root"/>


    <!-- ===================================================== -->
    <!-- 6️⃣ MENU → ACTION (STATIC)                             -->
    <!-- ===================================================== -->
    <!-- Ini yang paling penting untuk flow action=90 -->
    <menuitem name="List"
              id="sadaya_tender.menu_1_list"
              parent="sadaya_tender.menu_1"
              action="sadaya_tender.action_window"/>
    <!--
    Saat diklik:
    → resolve XML ID si_qut.action_window
    → ambil DB ID (misal 90)
    → buka: /web#action=90
    -->


    <!-- ===================================================== -->
    <!-- 7️⃣ MENU → SERVER ACTION (DYNAMIC)                     -->
    <!-- ===================================================== -->
    <menuitem name="Server to list"
              id="sadaya_tender.menu_server_list"
              parent="sadaya_tender.menu_2"
              action="sadaya_tender.action_server"/>
    <!--
    Saat diklik:
    → jalankan Python code di server action
    → return dictionary action
    → Odoo treat sebagai act_window
    -->


  </data>
</odoo>

