<odoo>
  <data>
    <record model="ir.ui.view" id="sadaya_tender.list">
      <field name="name">sadaya_tender list</field>
      <field name="model">sadaya_tender.sadaya_tender</field>
      <field name="arch" type="xml">
        <list>
          <field name="kode"/>
          <field name="nama"/>
          <field name="tahap"/>
        </list>
      </field>
    </record>

    <record model="ir.actions.act_window" id="sadaya_tender.action_window">
      <field name="name">sadaya_tender window</field>
      <field name="res_model">sadaya_tender.sadaya_tender</field>
      <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.server" id="sadaya_tender.action_server">
      <field name="name">sadaya_tender servers</field>
      <field name="model_id" ref="model_sadaya_tender_sadaya_tender"/>
      <field name="state">code</field>
      <field name="code">
        action = {
          "type": "ir.actions.act_window",   # jenis action
          "view_mode": "list,form",          # view yang diminta
          "res_model": "sadaya_tender.sadaya_tender",       # model saat ini
          "name": "sadaya_tender servers",
        } 
      </field>
    </record>

    <menuitem name="sadaya_tender" id="sadaya_tender.menu_root"/>

    <menuitem name="Menu 1"
              id="sadaya_tender.menu_1"
              parent="sadaya_tender.menu_root"/>
    <menuitem name="Menu 2"
              id="sadaya_tender.menu_2"
              parent="sadaya_tender.menu_root"/>

    <menuitem name="List"
              id="sadaya_tender.menu_1_list"
              parent="sadaya_tender.menu_1"
              action="sadaya_tender.action_window"/>
    <menuitem name="Server to list"
              id="sadaya_tender.menu_server_list"
              parent="sadaya_tender.menu_2"
              action="sadaya_tender.action_server"/>

  </data>
</odoo>

