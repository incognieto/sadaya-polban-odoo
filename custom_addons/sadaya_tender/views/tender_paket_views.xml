<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tender Paket Tree View -->
    <record id="view_tender_paket_tree" model="ir.ui.view">
        <field name="name">tender.paket.tree</field>
        <field name="model">tender.paket</field>
        <field name="arch" type="xml">
            <list string="Daftar Paket Tender">
                <field name="kode_tender"/>
                <field name="name"/>
                <field name="metode_pemilihan"/>
                <field name="hps" widget="monetary"/>
                <field name="status"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Tender Paket Form View -->
    <record id="view_tender_paket_form" model="ir.ui.view">
        <field name="name">tender.paket.form</field>
        <field name="model">tender.paket</field>
        <field name="arch" type="xml">
            <form string="Paket Tender">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="draft,announced,registration,evaluation,awarded"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="kode_tender"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="metode_pemilihan"/>
                        </group>
                        <group>
                            <field name="hps" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Deskripsi">
                            <field name="description"/>
                        </page>
                        <page string="Jadwal Tender">
                            <field name="jadwal_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                </list>
                            </field>
                        </page>
                        <page string="Dokumen Pemilihan (Pokja)">
                            <field name="dokumen_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="file_name" invisible="1"/>
                                    <field name="file" filename="file_name"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Dokumen Penawaran (Vendor)">
                            <field name="penawaran_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="vendor_id"/>
                                    <field name="nilai_penawaran" widget="monetary"/>
                                    <field name="status"/>
                                    <field name="skor_teknis"/>
                                    <field name="skor_harga"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tender Penawaran Form View (For Evaluation) -->
    <record id="view_tender_penawaran_form" model="ir.ui.view">
        <field name="name">tender.penawaran.form</field>
        <field name="model">tender.penawaran</field>
        <field name="arch" type="xml">
            <form string="Dokumen Penawaran">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="paket_id" readonly="1"/>
                            <field name="vendor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="nilai_penawaran" widget="monetary" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="file_name" invisible="1"/>
                            <field name="file_penawaran" filename="file_name" readonly="1"/>
                        </group>
                    </group>
                    <group string="Evaluasi Pokja" groups="sadaya_tender.group_tender_pokja">
                        <field name="skor_teknis"/>
                        <field name="skor_harga"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_tender_paket" model="ir.actions.act_window">
        <field name="name">Paket Tender</field>
        <field name="res_model">tender.paket</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_tender_penawaran" model="ir.actions.act_window">
        <field name="name">Semua Penawaran</field>
        <field name="res_model">tender.penawaran</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
