<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Public Tender List -->
    <template id="portal_tender_list" name="Daftar Tender SPSE">
        <t t-call="website.layout">
            <div id="wrap" class="container mt-4 mb-4">
                <h2>Pengumuman Tender / Seleksi</h2>
                <div class="row">
                    <div class="col-12">
                        <table class="table table-striped table-bordered">
                            <thead class="bg-primary text-white">
                                <tr>
                                    <th>Kode</th>
                                    <th>Nama Paket</th>
                                    <th>HPS</th>
                                    <th>Status</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="tenders" t-as="tender">
                                    <tr>
                                        <td><t t-esc="tender.kode_tender"/></td>
                                        <td><t t-esc="tender.name"/></td>
                                        <td><t t-esc="tender.hps" t-options="{'widget': 'monetary', 'display_currency': tender.currency_id}"/></td>
                                        <td><span class="badge badge-info"><t t-esc="tender.status"/></span></td>
                                        <td>
                                            <a t-attf-href="/tenders/#{tender.id}" class="btn btn-sm btn-primary">Detail</a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Tender Detail -->
    <template id="portal_tender_detail" name="Detail Tender">
        <t t-call="website.layout">
            <div id="wrap" class="container mt-4 mb-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h3><t t-esc="tender.name"/></h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Kode Tender:</strong> <t t-esc="tender.kode_tender"/><br/>
                                <strong>Metode:</strong> <t t-esc="tender.metode_pemilihan"/><br/>
                                <strong>HPS:</strong> <t t-esc="tender.hps" t-options="{'widget': 'monetary', 'display_currency': tender.currency_id}"/><br/>
                            </div>
                            <div class="col-md-6">
                                <strong>Status:</strong> <span class="badge badge-success"><t t-esc="tender.status"/></span>
                            </div>
                        </div>
                        
                        <hr/>
                        <h4>Jadwal Tahapan</h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Tahapan</th>
                                    <th>Mulai</th>
                                    <th>Selesai</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="tender.jadwal_ids" t-as="jadwal">
                                    <tr>
                                        <td><t t-esc="jadwal.name"/></td>
                                        <td><t t-esc="jadwal.date_start"/></td>
                                        <td><t t-esc="jadwal.date_end"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        
                        <div t-if="request.env.user.id != request.env.ref('base.public_user').id" class="mt-3">
                            <a href="/my/tenders" class="btn btn-success">Ikuti Tender / Upload Dokumen</a>
                        </div>
                        <div t-else="" class="mt-3">
                            <p class="text-danger">Silahkan <a href="/web/login">Login</a> untuk mengikuti tender ini.</p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
    <!-- My Tenders Dashboard -->
    <template id="portal_my_tenders" name="Dashboard Vendor">
        <t t-call="website.layout">
            <div class="container mt-4 mb-4">
                <h2>Dashboard Vendor: <t t-esc="partner.name"/></h2>
                
                <div t-if="partner.vendor_status != 'verified'" class="alert alert-warning">
                    <strong>Perhatian!</strong> Status verifikasi Anda saat ini: <b><t t-esc="partner.vendor_status"/></b>. Anda tidak bisa mengajukan penawaran sampai diverifikasi oleh Pokja.
                </div>
                
                <div t-if="partner.vendor_status == 'verified'" class="alert alert-success">
                    Status Akun: <b>Terverifikasi</b>. Anda dapat mengajukan penawaran pada tender yang aktif.
                </div>
                
                <h4>Riwayat Penawaran Anda</h4>
                <table class="table table-bordered">
                    <thead class="bg-secondary text-white">
                        <tr>
                            <th>Tender</th>
                            <th>No Penawaran</th>
                            <th>Harga Penawaran</th>
                            <th>Status Evaluasi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="bids" t-as="bid">
                            <tr>
                                <td><t t-esc="bid.paket_id.name"/></td>
                                <td><t t-esc="bid.name"/></td>
                                <td><t t-esc="bid.nilai_penawaran" t-options="{'widget': 'monetary', 'display_currency': bid.currency_id}"/></td>
                                <td><span class="badge badge-info"><t t-esc="bid.status"/></span></td>
                            </tr>
                        </t>
                        <tr t-if="not bids">
                            <td colspan="4" class="text-center">Belum ada penawaran yang diajukan.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </t>
    </template>
    
    <template id="portal_vendor_registration" name="Registrasi Vendor SPSE">
        <t t-call="website.layout">
            <div class="container mt-4 mb-4">
                <div class="alert alert-info">
                    Anda belum terdaftar sebagai Vendor SPSE. Silahkan hubungi panitia pengadaan untuk melengkapi data NIB dan NPWP di Profil Anda.
                </div>
            </div>
        </t>
    </template>
</odoo>
