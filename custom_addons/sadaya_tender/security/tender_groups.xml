<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_tender" model="ir.module.category">
            <field name="name">SPSE Tendering</field>
            <field name="description">Manajemen Tender dan Pengadaan</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_tender_pokja" model="res.groups">
            <field name="name">Pokja Pemilihan</field>
            <field name="category_id" ref="module_category_tender"/>
            <field name="comment">Akses untuk mengelola tahapan tender dan evaluasi penawaran.</field>
        </record>

        <record id="group_tender_admin" model="res.groups">
            <field name="name">Administrator / PPK</field>
            <field name="category_id" ref="module_category_tender"/>
            <field name="implied_ids" eval="[(4, ref('group_tender_pokja'))]"/>
            <field name="comment">Akses penuh untuk pembuatan paket, HPS, dan persetujuan.</field>
        </record>

        <!-- Record Rules -->
        <record id="rule_tender_penawaran_vendor" model="ir.rule">
            <field name="name">Vendor hanya bisa melihat penawarannya sendiri</field>
            <field name="model_id" ref="model_tender_penawaran"/>
            <field name="domain_force">[('vendor_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="rule_tender_penawaran_pokja" model="ir.rule">
            <field name="name">Pokja bisa melihat semua penawaran</field>
            <field name="model_id" ref="model_tender_penawaran"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_tender_pokja'))]"/>
        </record>
    </data>
</odoo>
