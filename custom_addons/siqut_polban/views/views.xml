<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_siqut_paket_list" model="ir.ui.view">
            <field name="name">siqut.paket.list</field>
            <field name="model">siqut.paket</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="nilai_hps"/>
                    <field name="jenis_kontrak"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_siqut_paket_form" model="ir.ui.view">
            <field name="name">siqut.paket.form</field>
            <field name="model">siqut.paket</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="nilai_hps"/>
                            <field name="jenis_kontrak"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_siqut_paket" model="ir.actions.act_window">
            <field name="name">Paket Pengadaan (RUP)</field>
            <field name="res_model">siqut.paket</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_siqut_root" name="SI-Qut" sequence="10"/>
        <menuitem id="menu_siqut_paket" name="Daftar RUP" parent="menu_siqut_root" action="action_siqut_paket" sequence="10"/>
    </data>
</odoo>