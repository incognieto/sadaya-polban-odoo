<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_procurement_package_tree" model="ir.ui.view">
    <field name="name">sadaya_rutin.procurement_package.tree</field>
    <field name="model">sadaya_rutin.procurement_package</field>
    <field name="arch" type="xml">
      <list>
        <field name="code"/>
        <field name="name"/>
        <field name="proposing_unit"/>
        <field name="procurement_type"/>
        <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
        <field name="status"/>
        <field name="start_date"/>
      </list>
    </field>
  </record>

  <record id="view_procurement_package_kanban" model="ir.ui.view">
    <field name="name">sadaya_rutin.procurement_package.kanban</field>
    <field name="model">sadaya_rutin.procurement_package</field>
    <field name="arch" type="xml">
      <kanban class="o_kanban_small_column">
        <templates>
          <t t-name="card">
            <div class="oe_kanban_global_click o_kanban_card">
              <div class="o_kanban_header">
                <strong><field name="name"/></strong>
              </div>
              <div class="o_kanban_content">
                <div><span class="text-muted">Unit Pengusul:</span> <field name="proposing_unit"/></div>
                <div><span class="text-muted">Jenis Pengadaan:</span> <field name="procurement_type"/></div>
                <div><span class="text-muted">Status:</span> <field name="status"/></div>
                <div><span class="text-muted">Tanggal Mulai:</span> <field name="start_date"/></div>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <record id="view_procurement_package_form" model="ir.ui.view">
    <field name="name">sadaya_rutin.procurement_package.form</field>
    <field name="model">sadaya_rutin.procurement_package</field>
    <field name="arch" type="xml">
      <form string="Paket">
        <header>
          <button name="action_to_negotiation_vendor" type="object" string="Kirim ke Vendor" class="btn-primary" invisible="status not in ('draft', 'revision')"/>
          <button name="action_to_negotiation_done" type="object" string="Terima Penawaran" class="btn-primary" invisible="status != 'negotiation_pp'"/>
          <button name="action_counter_offer" type="object" string="Counter Offer" class="btn-secondary" invisible="status != 'negotiation_pp'"/>
          <button name="action_to_negotiation_minutes" type="object" string="Buat BA Negosiasi" class="btn-secondary" invisible="status != 'negotiation_done'"/>
          <button name="action_to_spk_preparation" type="object" string="Persiapan SPK" class="btn-primary" invisible="status != 'negotiation_minutes'"/>
          <button name="action_to_spk_process" type="object" string="Proses SPK" class="btn-primary" invisible="status != 'spk_preparation'"/>
          <button name="action_to_delivery" type="object" string="Pengiriman" class="btn-primary" invisible="status != 'spk_process'"/>
          <button name="action_to_inspection" type="object" string="Pemeriksaan" class="btn-primary" invisible="status != 'delivery'"/>
          <button name="action_to_done" type="object" string="Selesaikan" class="btn-success" invisible="status != 'inspection'"/>
          <button name="action_set_revision" type="object" string="Revisi" class="btn-warning" invisible="status in ('draft', 'done', 'cancelled')"/>
          <button name="action_set_addendum" type="object" string="Addendum" class="btn-secondary" invisible="status not in ('spk_process', 'done')"/>
          <button name="action_reset_draft" type="object" string="Kembalikan ke Draft" class="btn-secondary" invisible="status not in ('revision', 'cancelled')"/>
          <button name="action_cancel" type="object" string="Batalkan" class="btn-danger" invisible="status in ('done', 'cancelled')"/>
          <button name="action_print_ba_negotiation" type="object" string="Cetak BA Negosiasi" class="btn-info" invisible="status not in ('negotiation_minutes', 'spk_preparation', 'spk_process', 'delivery', 'inspection', 'done')"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1><field name="name" placeholder="Nama paket..."/></h1>
            <div class="text-muted">
              <field name="code" placeholder="Kode paket..."/>
            </div>
          </div>

          <group>
            <group>
              <field name="procurement_type"/>
              <field name="status" widget="statusbar"/>
              <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
              <field name="currency_id" invisible="1"/>
            </group>
            <group>
              <field name="proposing_unit"/>
              <field name="contract_count" readonly="1"/>
              <field name="requires_ppk" readonly="1"/>
            </group>
          </group>

          <group>
            <group>
              <field name="start_date"/>
            </group>
            <group>
              <field name="end_date"/>
            </group>
          </group>

          <notebook>
            <page string="Data Permintaan">
              <group>
                <group>
                  <field name="item_name"/>
                  <field name="item_qty"/>
                </group>
                <group>
                  <field name="estimated_budget" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                  <field name="request_notes"/>
                </group>
              </group>
              <group>
                <field name="item_spec"/>
              </group>
            </page>

            <page string="Negosiasi">
              <group>
                <group>
                  <field name="vendor_id"/>
                  <field name="vendor_stock_confirmed"/>
                  <field name="negotiation_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                  <field name="admin_counter_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </group>
                <group>
                  <field name="vendor_offer_notes"/>
                  <field name="negotiation_notes"/>
                  <field name="admin_review_notes"/>
                  <field name="ba_negotiation_filename" invisible="1"/>
                  <field name="ba_negotiation_file" filename="ba_negotiation_filename"/>
                </group>
              </group>
              <group>
                <field name="negotiation_history"/>
              </group>
            </page>

            <page string="Surat Pesanan (SP)">
              <group>
                <group>
                  <field name="sp_number"/>
                  <field name="sp_date"/>
                </group>
                <group>
                  <field name="sp_signed_ppk"/>
                  <field name="sp_signed_vendor"/>
                  <field name="sp_signed_filename" invisible="1"/>
                  <field name="sp_signed_file" filename="sp_signed_filename"/>
                </group>
              </group>
            </page>

            <page string="Pengiriman">
              <group>
                <field name="delivery_date"/>
                <field name="delivery_notes"/>
              </group>
            </page>

            <page string="Pemeriksaan &amp; Serah Terima">
              <group>
                <group>
                  <field name="inspection_status"/>
                  <field name="inspection_notes"/>
                </group>
                <group>
                  <field name="bast_number"/>
                  <field name="bast_date"/>
                </group>
              </group>
              <group>
                <field name="bast_signed_pphp"/>
                <field name="bast_signed_user"/>
                <field name="bast_signed_vendor"/>
              </group>
            </page>

            <page string="Kontrak">
              <field name="contract_ids" context="{'default_package_id': id}">
                <list editable="bottom">
                  <field name="name"/>
                  <field name="officer_name"/>
                  <field name="vendor_name"/>
                  <field name="hps_value"/>
                  <field name="status"/>
                  <field name="start_date"/>
                </list>
              </field>
            </page>

            <page string="Selesai">
              <group>
                <field name="completion_notes"/>
              </group>
            </page>

            <page string="Chatter">
              <field name="message_follower_ids" widget="mail_followers"/>
              <field name="activity_ids" widget="mail_activity"/>
              <field name="message_ids" widget="mail_thread"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_procurement_package_pivot" model="ir.ui.view">
    <field name="name">sadaya_rutin.procurement_package.pivot</field>
    <field name="model">sadaya_rutin.procurement_package</field>
    <field name="arch" type="xml">
      <pivot>
        <field name="status" type="row"/>
        <field name="amount_total" type="measure"/>
      </pivot>
    </field>
  </record>

  <record id="view_procurement_package_search" model="ir.ui.view">
    <field name="name">sadaya_rutin.procurement_package.search</field>
    <field name="model">sadaya_rutin.procurement_package</field>
    <field name="arch" type="xml">
      <search>
        <field name="code" string="Kode Paket"/>
        <field name="name" string="Nama Paket"/>
        <field name="procurement_type" string="Jenis Pengadaan"/>
        <field name="status" string="Status Paket"/>
        <field name="proposing_unit" string="Unit Pengusul"/>
        <field name="start_date" string="Tanggal Mulai"/>
        <field name="end_date" string="Tanggal Selesai"/>
      </search>
    </field>
  </record>

  <record id="action_sadaya_rutin_packages" model="ir.actions.act_window">
    <field name="name">Paket</field>
    <field name="res_model">sadaya_rutin.procurement_package</field>
    <field name="view_mode">list,form,pivot</field>
    <field name="search_view_id" ref="view_procurement_package_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Tidak ada data</p>
      <p>Buat paket pengadaan dulu untuk mulai.</p>
    </field>
  </record>
</odoo>
