<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================== -->
    <!-- 0. TEMPLATE LAYOUT SIDEBAR UTAMA           -->
    <!-- ========================================== -->
    <template id="portal_sidebar_layout" name="Portal Sidebar Layout">
        <t t-call="website.layout">
            <div id="wrap" class="bg-light pb-5" style="min-height: 100vh;">
                <div class="container-fluid pt-4 px-4">
                    <div class="row">
                        <!-- SIDEBAR MENU KIRI -->
                        <div class="col-md-2 mb-4">
                            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 20px;">
                                <div class="card-body p-3">
                                    <!-- Profil User -->
                                    <div class="d-flex align-items-center mb-4 p-2">
                                        <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                            <i class="fa fa-user"/>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold text-truncate" style="max-width: 120px;"><t t-esc="env.user.name"/></h6>
                                            <small class="text-muted">Badan Usaha / User</small>
                                        </div>
                                    </div>

                                    <p class="text-muted small fw-bold mb-2 px-2">MENU</p>
                                    <div class="list-group list-group-flush border-0">
                                        <!-- Link Dashboard -->
                                        <a href="/purchase-portal/dashboard" 
                                           t-attf-class="list-group-item list-group-item-action border-0 rounded mb-2 #{'active bg-success bg-opacity-25 text-success fw-bold' if active_menu == 'dashboard' else 'text-secondary'}">
                                            <i class="fa fa-th-large me-2"></i> Dashboard
                                        </a>
                                        <!-- Link Paket -->
                                        <a href="/purchase-portal/packages" 
                                           t-attf-class="list-group-item list-group-item-action border-0 rounded mb-2 #{'active bg-success bg-opacity-25 text-success fw-bold' if active_menu == 'paket' else 'text-secondary'}">
                                            <i class="fa fa-truck me-2"></i> Paket
                                        </a>
                                        <!-- Link Kontrak -->
                                        <a href="/purchase-portal/contracts" 
                                           t-attf-class="list-group-item list-group-item-action border-0 rounded mb-2 #{'active bg-success bg-opacity-25 text-success fw-bold' if active_menu == 'kontrak' else 'text-secondary'}">
                                            <i class="fa fa-file-text-o me-2"></i> Kontrak
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- KONTEN UTAMA KANAN -->
                        <div class="col-md-10">
                            <!-- Tempat konten spesifik halaman akan dimasukkan -->
                            <t t-out="0"/>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ========================================== -->
    <!-- 1. TEMPLATE DASHBOARD                      -->
    <!-- ========================================== -->
    <template id="portal_dashboard" name="Dashboard Sadaya Rutin">
        <t t-call="sadaya_rutin.portal_sidebar_layout">
            <!-- Memberitahu layout bahwa menu yang aktif adalah dashboard -->
            <t t-set="active_menu" t-value="'dashboard'"/>
            
            <div class="mb-4">
                <h4 class="fw-bold mb-1">Sadaya Rutin</h4>
                <p class="text-muted small mb-4">Sistem Informasi Sadaya Rutin</p>
                <h3 class="fw-bold text-success mb-3">Halo, <t t-esc="env.user.name"/>, Selamat Datang!</h3>
                <div class="d-flex gap-2 mb-4">
                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success">Transparansi</span>
                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success">Akuntabilitas</span>
                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success">Efisiensi</span>
                </div>
            </div>

            <!-- Banner Utama -->
            <div class="card border-0 rounded-4 mb-4" style="background: linear-gradient(135deg, #d1f2e6 0%, #e6f9f0 100%);">
                <div class="card-body p-5">
                    <span class="badge bg-white text-success border mb-3 rounded-pill px-3 py-2"><i class="fa fa-star me-1"/> Modul Unggulan</span>
                    <h2 class="fw-bold text-dark mb-3">Sadaya Rutin – Sistem Informasi Sadaya Rutin</h2>
                    <p class="text-muted w-75 mb-4">Sistem Informasi Sadaya Rutin untuk mengelola transaksi pengadaan barang dan jasa secara efisien dan transparan.</p>
                    <a href="#" class="btn btn-outline-success bg-white fw-bold rounded-pill px-4">Lihat Panduan</a>
                </div>
            </div>

            <!-- Kartu Fitur Bawah -->
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 p-4 border-top border-warning border-3">
                        <i class="fa fa-folder text-warning fa-2x mb-3"/>
                        <h5 class="fw-bold">Ajukan Permintaan Pembelian</h5>
                        <p class="text-muted small mb-4">Buat dan kelola permintaan pengadaan barang/jasa secara digital – dari kebutuhan hingga persetujuan.</p>
                        <a href="/purchase-portal/packages" class="text-secondary text-decoration-none small fw-bold mt-auto">Mulai Cepat</a>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 p-4 border-top border-info border-3">
                        <i class="fa fa-th-large text-info fa-2x mb-3"/>
                        <h5 class="fw-bold">Kelola Kontrak</h5>
                        <p class="text-muted small mb-4">Pantau masa berlaku, nilai kontrak, dan progres pelaksanaan pekerjaan dengan mudah kapan saja.</p>
                        <a href="/purchase-portal/contracts" class="text-secondary text-decoration-none small fw-bold mt-auto">Manajemen Kontrak</a>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 p-4 border-top border-success border-3">
                        <i class="fa fa-calendar text-success fa-2x mb-3"/>
                        <h5 class="fw-bold">Atur Jadwal &amp; Prioritas</h5>
                        <p class="text-muted small mb-4">Rencanakan proses pengadaan dengan timeline yang jelas. Tetapkan prioritas dan atur tenggat waktu.</p>
                        <a href="#" class="text-secondary text-decoration-none small fw-bold mt-auto">Perencanaan</a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ========================================== -->
    <!-- 2. TEMPLATE DAFTAR PAKET                   -->
    <!-- ========================================== -->
    <template id="portal_packages" name="Daftar Paket Pengadaan">
        <t t-call="sadaya_rutin.portal_sidebar_layout">
            <t t-set="active_menu" t-value="'paket'"/>

            <div class="mb-4">
                <h4 class="fw-bold mb-1">Sadaya Rutin</h4>
                <p class="text-muted small">Sistem Informasi Sadaya Rutin</p>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-0">Paket Penyedia</h5>
                    <p class="text-muted small mb-4">Dashboard > Daftar Paket</p>

                    <!-- Filter Bar -->
                    <form method="get" class="row g-3 align-items-center mb-4">
                        <div class="col-md-3">
                            <select name="procurement_type" class="form-select border-0 bg-light rounded-pill px-3">
                                <option value="">Jenis Pengadaan</option>
                                <t t-foreach="procurement_types" t-as="p_type">
                                    <option t-att-value="p_type[0]" t-att-selected="p_type[0] == filters.get('procurement_type')"><t t-esc="p_type[1]"/></option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select name="status" class="form-select border-0 bg-light rounded-pill px-3">
                                <option value="">Status Paket</option>
                                <t t-foreach="statuses" t-as="st">
                                    <option t-att-value="st[0]" t-att-selected="st[0] == filters.get('status')"><t t-esc="st[1]"/></option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 rounded-start-pill ps-4"><i class="fa fa-search text-muted"/></span>
                                <input type="text" name="query" class="form-control bg-light border-0 rounded-end-pill py-2" placeholder="Cari paket..." t-att-value="filters.get('query')"/>
                            </div>
                        </div>
                        <button type="submit" class="d-none">Filter</button>
                    </form>

                    <!-- Tabel Data -->
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light text-secondary text-center small">
                                <tr>
                                    <th>Nama Paket</th>
                                    <th>Unit Pengusul</th>
                                    <th>Jenis Pengadaan</th>
                                    <th>Status</th>
                                    <th>Tanggal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="not packages">
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <i class="fa fa-file-text-o fa-3x text-muted border p-4 rounded-circle mb-3"/>
                                            <h6 class="fw-bold">Tidak ada data</h6>
                                            <p class="text-muted small">Belum ada data yang tersedia untuk ditampilkan saat ini</p>
                                        </td>
                                    </tr>
                                </t>
                                <t t-foreach="packages" t-as="package">
                                    <tr class="text-center">
                                        <td class="text-start fw-bold"><span t-field="package.name"/></td>
                                        <td><span t-field="package.proposing_unit"/></td>
                                        <td><span t-field="package.procurement_type"/></td>
                                        <td><span t-field="package.status" class="badge bg-success bg-opacity-10 text-success rounded-pill px-3"/></td>
                                        <td><span t-field="package.start_date"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ========================================== -->
    <!-- 3. TEMPLATE DAFTAR KONTRAK                 -->
    <!-- ========================================== -->
    <template id="portal_contracts" name="Daftar Kontrak">
        <t t-call="sadaya_rutin.portal_sidebar_layout">
            <t t-set="active_menu" t-value="'kontrak'"/>

            <div class="mb-4">
                <h4 class="fw-bold mb-1">Sadaya Rutin</h4>
                <p class="text-muted small">Sistem Informasi Sadaya Rutin</p>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-0">Kontrak</h5>
                    <p class="text-muted small mb-4">Dashboard > Daftar Kontrak</p>

                    <!-- Filter Bar -->
                    <form method="get" class="row g-3 align-items-center mb-4">
                        <div class="col-md-4">
                            <select name="status" class="form-select border-0 bg-light rounded-pill px-3">
                                <option value="">Pilih Status Kontrak</option>
                                <t t-foreach="statuses" t-as="st">
                                    <option t-att-value="st[0]" t-att-selected="st[0] == filters.get('status')"><t t-esc="st[1]"/></option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 rounded-start-pill ps-4"><i class="fa fa-search text-muted"/></span>
                                <input type="text" name="query" class="form-control bg-light border-0 rounded-end-pill py-2" placeholder="Cari kontrak..." t-att-value="filters.get('query')"/>
                            </div>
                        </div>
                        <button type="submit" class="d-none">Filter</button>
                    </form>

                    <!-- Tabel Data -->
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light text-secondary text-center small">
                                <tr>
                                    <th>Nama Paket</th>
                                    <th>Pejabat Pembuat</th>
                                    <th>Penyedia</th>
                                    <th>Nilai HPS</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="not contracts">
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <i class="fa fa-file-text-o fa-3x text-muted border p-4 rounded-circle mb-3"/>
                                            <h6 class="fw-bold">Tidak ada data</h6>
                                            <p class="text-muted small">Belum ada data yang tersedia untuk ditampilkan saat ini</p>
                                        </td>
                                    </tr>
                                </t>
                                <t t-foreach="contracts" t-as="contract">
                                    <tr class="text-center">
                                        <td class="text-start fw-bold"><span t-field="contract.package_id.name"/></td>
                                        <td><span t-field="contract.officer_name"/></td>
                                        <td><span t-field="contract.vendor_name"/></td>
                                        <td class="text-end fw-semibold text-success"><span t-field="contract.hps_value"/></td>
                                        <td><span t-field="contract.status" class="badge bg-success bg-opacity-10 text-success rounded-pill px-3"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>