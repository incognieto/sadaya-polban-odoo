<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================== -->
    <!-- 0. TEMPLATE LAYOUT UTAMA RUTIN           -->
    <!-- ========================================== -->
    <template id="portal_rutin_layout" name="Portal Rutin Layout">
        <t t-call="website.layout">
            <div id="wrap" class="o_sadaya_frontend sr-app-shell">
                <header class="sr-app-header">
                    <div class="container sr-app-header__inner">
                        <div>
                            <p class="sr-app-eyebrow">Sistem Informasi Pengadaan Rutin</p>
                            <a href="/sadaya-rutin/dashboard" class="sr-app-brand">Sadaya Rutin</a>
                        </div>
                        <nav class="sr-app-nav" aria-label="Navigasi utama">
                            <a href="/sadaya-rutin/dashboard" t-att-class="'active' if active_menu == 'dashboard' else ''">Dashboard</a>
                            <a href="/sadaya-rutin/paket" t-att-class="'active' if active_menu == 'paket' else ''">Paket</a>
                            <a href="/sadaya-rutin/kontrak" t-att-class="'active' if active_menu == 'kontrak' else ''">Kontrak</a>
                        </nav>
                        <div class="d-flex align-items-center gap-3">
                            <span class="sr-app-eyebrow mb-0" style="color: var(--sr-text); font-weight: bold;"><i class="fa fa-user me-1"/> <t t-esc="env.user.name"/></span>
                        </div>
                    </div>
                </header>

                <!-- KONTEN UTAMA HALAMAN AKAN DIMASUKKAN DI SINI -->
                <t t-out="0"/>

                <footer class="sr-app-footer">
                    <div class="container sr-app-footer__inner">
                        <div>
                            <p class="sr-app-eyebrow">Sadaya Rutin</p>
                            <strong>E-Purchasing untuk belanja operasional rutin.</strong>
                        </div>
                        <div class="sr-app-footer__meta">
                            <span>Powered by Odoo</span>
                        </div>
                    </div>
                </footer>
            </div>
        </t>
    </template>

    <!-- ========================================== -->
    <!-- 1. TEMPLATE DASHBOARD                      -->
    <!-- ========================================== -->
    <template id="portal_dashboard" name="Dashboard Sadaya Rutin">
        <t t-call="sadaya_rutin.portal_rutin_layout">
            <t t-set="active_menu" t-value="'dashboard'"/>
            
            <section class="sr-hero">
                <div class="container">
                    <div class="sr-hero__inner">
                        <div>
                            <p class="sr-kicker">Portal Operasional</p>
                            <h1>Dashboard Sadaya Rutin</h1>
                            <p class="sr-lead">
                                Halo, <t t-esc="env.user.name"/>, Selamat Datang! Kelola belanja operasional rutin dari permintaan, negosiasi, SPK hingga serah terima secara transparan.
                            </p>
                            <div class="sr-hero__stats">
                                <div>
                                    <span>Paket Aktif</span>
                                    <strong><t t-esc="package_active_count"/></strong>
                                </div>
                                <div>
                                    <span>Menunggu SPK</span>
                                    <strong><t t-esc="package_pending_spk_count"/></strong>
                                </div>
                                <div>
                                    <span>Selesai Bulan Ini</span>
                                    <strong><t t-esc="package_done_month_count"/></strong>
                                </div>
                            </div>
                        </div>
                        <div class="sr-hero__actions">
                            <a href="/sadaya-rutin/paket" class="btn btn-primary">Lihat Paket</a>
                            <a href="/sadaya-rutin/kontrak" class="btn btn-outline-primary">Kelola Kontrak</a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="sr-section sr-section--alt">
                <div class="container">
                    <div class="sr-grid-header">
                        <div>
                            <h2>Fitur Unggulan</h2>
                            <p>Kemudahan pengadaan dalam genggaman Anda.</p>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <article class="sr-card sr-card--detail h-100 border-top border-warning border-3">
                                <div class="sr-card__top">
                                    <h3>Pantau Penawaran</h3>
                                    <i class="fa fa-folder text-warning fa-2x"/>
                                </div>
                                <p class="text-muted small">Lihat paket yang sudah dipublikasikan, lalu kirim penawaran harga dan konfirmasi stok melalui portal.</p>
                            </article>
                        </div>
                        <div class="col-12 col-md-4">
                            <article class="sr-card sr-card--detail h-100 border-top border-info border-3">
                                <div class="sr-card__top">
                                    <h3>Kelola Kontrak</h3>
                                    <i class="fa fa-th-large text-info fa-2x"/>
                                </div>
                                <p class="text-muted small">Pantau masa berlaku, nilai kontrak, dan progres pelaksanaan pekerjaan dengan mudah kapan saja.</p>
                            </article>
                        </div>
                        <div class="col-12 col-md-4">
                            <article class="sr-card sr-card--detail h-100 border-top border-success border-3">
                                <div class="sr-card__top">
                                    <h3>Atur Jadwal</h3>
                                    <i class="fa fa-calendar text-success fa-2x"/>
                                </div>
                                <p class="text-muted small">Rencanakan proses pengadaan dengan timeline yang jelas. Tetapkan prioritas dan atur tenggat waktu.</p>
                            </article>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ========================================== -->
    <!-- 2. TEMPLATE DAFTAR PAKET                   -->
    <!-- ========================================== -->
    <template id="portal_packages" name="Daftar Paket Sadaya Rutin">
        <t t-call="sadaya_rutin.portal_rutin_layout">
            <t t-set="active_menu" t-value="'paket'"/>

            <section class="sr-page-header">
                <div class="container">
                    <p class="sr-kicker">Portal Operasional</p>
                    <h1>Daftar Paket Rutin</h1>
                    <p class="sr-lead">Dashboard > Daftar Paket</p>
                </div>
            </section>

            <section class="sr-section sr-section--form">
                <div class="container">
                    <form method="get" class="sr-form sr-form--inline mb-4">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-2">
                                <label class="sr-field-label">Jenis</label>
                                <select name="procurement_type" class="form-select sr-input">
                                    <option value="">Semua</option>
                                    <t t-foreach="procurement_types" t-as="p_type">
                                        <option t-att-value="p_type[0]" t-att-selected="p_type[0] == filters.get('procurement_type')"><t t-esc="p_type[1]"/></option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="sr-field-label">Status</label>
                                <select name="status" class="form-select sr-input">
                                    <option value="">Semua</option>
                                    <t t-foreach="statuses" t-as="st">
                                        <option t-att-value="st[0]" t-att-selected="st[0] == filters.get('status')"><t t-esc="st[1]"/></option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="sr-field-label">Cari</label>
                                <input type="text" name="query" class="form-control sr-input" placeholder="Cari paket..." t-att-value="filters.get('query')"/>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check pt-2">
                                    <input class="form-check-input" type="checkbox" id="filterMyPackages" name="my_packages" value="1" t-att-checked="filters.get('my_packages') and 'checked' or None" onchange="this.form.submit()"/>
                                    <label class="form-check-label sr-field-label" for="filterMyPackages" style="margin-bottom:0; cursor:pointer;">Hanya paket saya (Vendor)</label>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-dark sr-submit w-100">Filter</button>
                            </div>
                        </div>
                    </form>

                    <div class="row g-3">
                        <t t-foreach="packages" t-as="package">
                            <div class="col-12 col-lg-6">
                                <article class="sr-card sr-card--detail">
                                    <div class="sr-card__top">
                                        <div>
                                            <span class="sr-label"><span t-field="package.status"/></span>
                                            <h3><t t-esc="package.name"/></h3>
                                            <p class="text-muted small mt-1 mb-0">Kode: <t t-esc="package.code"/></p>
                                        </div>
                                        <strong><span t-field="package.amount_total" t-options="{'widget': 'monetary', 'display_currency': package.currency_id}"/></strong>
                                    </div>
                                    <dl class="sr-dl">
                                        <div><dt>Unit Pengusul</dt><dd><t t-esc="package.proposing_unit"/></dd></div>
                                        <div><dt>Tanggal Mulai</dt><dd><span t-field="package.start_date"/></dd></div>
                                    </dl>
                                    <div class="sr-actions">
                                        <a t-attf-href="/sadaya-rutin/paket/#{package.id}" class="btn btn-sm btn-outline-primary">Lihat Detail</a>
                                    </div>
                                </article>
                            </div>
                        </t>
                        <t t-if="not packages">
                            <div class="col-12">
                                <div class="sr-card sr-empty-card p-4 text-center">
                                    Belum ada data paket yang tersedia untuk ditampilkan saat ini.
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ========================================== -->
    <!-- 2B. TEMPLATE DETAIL PAKET                  -->
    <!-- ========================================== -->
    <template id="portal_package_detail" name="Detail Paket Sadaya Rutin">
        <t t-call="sadaya_rutin.portal_rutin_layout">
            <t t-set="active_menu" t-value="'paket'"/>

            <section class="sr-page-header" style="padding-bottom: 1rem;">
                <div class="container">
                    <p class="sr-kicker">Detail Paket</p>
                    <h1><t t-esc="package.name"/></h1>
                    <p class="sr-lead mb-2">Kode: <t t-esc="package.code"/></p>
                    <span class="sr-label" style="margin-bottom:0;"><span t-field="package.status"/></span>
                </div>
            </section>

            <section class="sr-section">
                <div class="container">
                    <!-- Alerts Based on Status -->
                    <t t-if="package.status == 'negotiation_vendor'">
                        <t t-if="package.vendor_id and env.user.partner_id.id in (package.vendor_id.id, package.vendor_id.parent_id.id)">
                            <div class="sr-notice alert alert-success">
                                <strong>Permintaan sudah diterima oleh vendor!</strong><br/>
                                Isi penawaran harga dan konfirmasi stok sebelum dikirim ke PP untuk direview.
                                <t t-if="package.admin_counter_price">
                                    <br/>Harga counter admin: <strong><span t-field="package.admin_counter_price" t-options="{'widget': 'monetary', 'display_currency': package.currency_id}"/></strong>
                                </t>
                            </div>
                            <form class="sr-form mb-4" t-att-action="'/sadaya-rutin/paket/%s/submit-offer' % package.id" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <h4 class="mb-3">Kirim Penawaran</h4>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="sr-field-label">Vendor</label>
                                        <input type="text" name="vendor_id_name" class="form-control sr-input" t-att-value="package.vendor_id.name" readonly="readonly"/>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="sr-field-label">Harga Penawaran</label>
                                        <input type="number" name="negotiation_price" step="0.01" class="form-control sr-input" t-att-value="package.negotiation_price or ''"/>
                                    </div>
                                    <div class="col-md-12">
                                        <label class="sr-field-label">Catatan Penawaran</label>
                                        <textarea name="vendor_offer_notes" class="form-control sr-input" rows="3"><t t-esc="package.vendor_offer_notes or ''"/></textarea>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="vendor_stock_confirmed" value="1" id="vendor_stock_confirmed" t-att-checked="package.vendor_stock_confirmed and 'checked' or None" required="required" onchange="if(this.checked) { this.style.boxShadow=''; this.style.borderColor=''; }"/>
                                            <label class="form-check-label sr-field-label" for="vendor_stock_confirmed" style="cursor:pointer;">Saya mengonfirmasi stok tersedia</label>
                                        </div>
                                    </div>
                                    <div class="col-12 sr-actions">
                                        <button type="submit" class="btn btn-primary sr-submit" onclick="if(!document.getElementById('vendor_stock_confirmed').checked) { document.getElementById('vendor_stock_confirmed').style.boxShadow='0 0 0 0.25rem rgba(220, 53, 69, 0.5)'; document.getElementById('vendor_stock_confirmed').style.borderColor='#dc3545'; }">Kirim Penawaran</button>
                                        <button type="submit" class="btn btn-outline-danger" style="border-radius:999px; padding:0.8rem 1.25rem;" formaction="/sadaya-rutin/paket/#{package.id}/reject-offer" formnovalidate="formnovalidate">Tolak / Stok Habis</button>
                                    </div>
                                </div>
                            </form>
                        </t>
                        <t t-else="">
                            <div class="sr-notice alert alert-info">
                                <strong>Status: Negosiasi (Penyedia)</strong><br/>
                                Hanya vendor yang ditunjuk yang dapat mengisi penawaran. Menunggu respon dari vendor.
                            </div>
                        </t>
                    </t>

                    <t t-if="package.status == 'negotiation_pp'">
                        <t t-if="package.vendor_id and env.user.partner_id.id in (package.vendor_id.id, package.vendor_id.parent_id.id)">
                            <div class="sr-notice alert alert-warning">
                                <strong>Penawaran sedang direview admin!</strong><br/>
                                Vendor menunggu hasil review admin/PP. Jika ada counter-offer, status akan kembali ke Negosiasi (Penyedia).
                                <t t-if="package.admin_counter_price">
                                    <br/>Counter terbaru admin: <strong><span t-field="package.admin_counter_price" t-options="{'widget': 'monetary', 'display_currency': package.currency_id}"/></strong>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="sr-notice alert alert-warning">
                                <strong>Status: Negosiasi (PP)</strong><br/>
                                Admin sedang mereview penawaran dari vendor.
                            </div>
                        </t>
                    </t>

                    <t t-if="package.status == 'delivery'">
                        <t t-if="package.vendor_id and env.user.partner_id.id in (package.vendor_id.id, package.vendor_id.parent_id.id)">
                            <t t-if="package.delivery_date">
                                <div class="sr-notice alert alert-info">
                                    <strong>Jadwal Pengiriman Telah Diajukan!</strong><br/>
                                    Barang akan dikirimkan pada <strong><t t-esc="package.delivery_date"/></strong>. Menunggu pemeriksaan dari Tim Teknis.
                                </div>
                            </t>
                            <t t-if="not package.delivery_date">
                                <t t-if="request.params.get('error')">
                                    <div class="sr-notice alert alert-danger">
                                        <strong>Pengajuan Ditolak!</strong><br/>
                                        <t t-esc="request.params.get('error')"/>
                                    </div>
                                </t>
                                <div class="sr-notice alert alert-success">
                                    <strong>Waktunya Pengiriman!</strong><br/>
                                    Silakan tentukan jadwal pengiriman. Catatan: Pengiriman hanya dapat dilakukan pada hari kerja (Senin - Jumat).
                                </div>
                                <form class="sr-form mb-4" t-att-action="'/sadaya-rutin/paket/%s/submit-delivery' % package.id" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <h4 class="mb-3">Jadwal Pengiriman</h4>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="sr-field-label">Tanggal Pengiriman</label>
                                            <input type="date" name="delivery_date" class="form-control sr-input" required="required"/>
                                        </div>
                                        <div class="col-md-12">
                                            <label class="sr-field-label">Catatan Pengiriman</label>
                                            <textarea name="delivery_notes" class="form-control sr-input" rows="3"></textarea>
                                        </div>
                                        <div class="col-12 sr-actions">
                                            <button type="submit" class="btn btn-primary sr-submit">Ajukan Jadwal Pengiriman</button>
                                        </div>
                                    </div>
                                </form>
                            </t>
                        </t>
                        <t t-else="">
                            <div class="sr-notice alert alert-info">
                                <strong>Status: Pengiriman</strong><br/>
                                Menunggu jadwal pengiriman dari vendor atau proses pengiriman sedang berlangsung.
                            </div>
                        </t>
                    </t>

                    <t t-if="package.status == 'inspection'">
                        <t t-if="package.vendor_id and env.user.partner_id.id in (package.vendor_id.id, package.vendor_id.parent_id.id)">
                            <t t-if="package.inspection_status == 'not_ok'">
                                <t t-if="package.vendor_revision_requested">
                                    <div class="sr-notice alert alert-warning">
                                        <strong>⏳ Menunggu Persetujuan Tim Teknis (Revisi)</strong><br/>
                                        Anda telah mengajukan kesanggupan untuk melakukan revisi (pengiriman ulang/perbaikan). Tim Teknis sedang memproses permintaan ini.
                                    </div>
                                </t>
                                <t t-elif="package.vendor_cancellation_requested">
                                    <div class="sr-notice alert alert-warning">
                                        <strong>⏳ Menunggu Persetujuan Tim Teknis (Pembatalan)</strong><br/>
                                        Anda telah mengajukan pembatalan pesanan. Tim Teknis sedang memproses permintaan ini.
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="sr-notice alert alert-danger">
                                        <strong>⚠️ Pemberitahuan Ketidaksesuaian Barang/Jasa</strong><br/>
                                        Tim Teknis telah memeriksa barang/jasa dan menyatakan <strong>Tidak Sesuai</strong>.<br/>
                                        <strong>Catatan:</strong> <t t-esc="package.inspection_notes"/><br/><br/>
                                        Harap berikan tanggapan Anda di bawah ini:
                                    </div>
                                    <div class="row g-3 mb-4">
                                        <div class="col-md-6">
                                            <form class="sr-form" t-att-action="'/sadaya-rutin/paket/%s/request-revision' % package.id" method="post">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <div class="sr-card p-3 border-warning" style="border: 2px solid #ffc107; height: 100%;">
                                                    <h5 class="text-warning"><i class="fa fa-refresh me-2"></i>Sanggup Revisi</h5>
                                                    <p class="small text-muted mb-3">Pilih opsi ini jika Anda sanggup mengirimkan ulang atau memperbaiki barang/jasa agar sesuai spesifikasi.</p>
                                                    <button type="submit" class="btn btn-warning w-100" onclick="return confirm('Apakah Anda yakin sanggup melakukan Revisi?');">
                                                        Request Revisi
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                        <div class="col-md-6">
                                            <form class="sr-form" t-att-action="'/sadaya-rutin/paket/%s/request-cancellation' % package.id" method="post" id="formCancelRequest">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <div class="sr-card p-3 border-danger" style="border: 2px solid #dc3545; height: 100%;">
                                                    <h5 class="text-danger"><i class="fa fa-times-circle me-2"></i>Tidak Sanggup / Batal</h5>
                                                    <p class="small text-muted mb-2">Pilih opsi ini jika Anda tidak sanggup memenuhi pesanan.</p>
                                                    <input type="text" name="cancellation_reason" class="form-control form-control-sm mb-3" placeholder="Alasan tidak sanggup..." required="required"/>
                                                    <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Apakah Anda yakin ingin membatalkan pesanan ini?');">
                                                        Request Batal
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="sr-notice alert alert-info">
                                    <strong>Status: Pemeriksaan</strong><br/>
                                    Tim Teknis sedang melakukan pemeriksaan terhadap barang/jasa yang Anda kirimkan.
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <div class="sr-notice alert alert-info">
                                <strong>Status: Pemeriksaan</strong><br/>
                                Tim Teknis sedang melakukan pemeriksaan barang/jasa.
                            </div>
                        </t>
                    </t>

                    <div class="sr-card sr-card--detail mb-4">
                        <div class="sr-card__top">
                            <h3>Informasi Permintaan</h3>
                        </div>
                        <dl class="sr-dl">
                            <div><dt>Nama Barang</dt><dd><t t-esc="package.item_name"/></dd></div>
                            <div><dt>Jumlah</dt><dd><t t-esc="package.item_qty"/></dd></div>
                            <div><dt>Estimasi Anggaran</dt><dd><span t-field="package.estimated_budget" t-options="{'widget': 'monetary', 'display_currency': package.currency_id}"/></dd></div>
                            <div style="grid-column: 1 / -1"><dt>Spesifikasi</dt><dd><t t-esc="package.item_spec"/></dd></div>
                        </dl>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-12 col-md-6">
                            <div class="sr-card sr-card--detail h-100">
                                <div class="sr-card__top">
                                    <h3>Negosiasi &amp; SPK</h3>
                                </div>
                                <dl class="sr-dl" style="grid-template-columns: 1fr;">
                                    <div><dt>Vendor</dt><dd><t t-esc="package.vendor_id.name or '-'"/></dd></div>
                                    <div><dt>Harga Negosiasi</dt><dd><span t-field="package.negotiation_price" t-options="{'widget': 'monetary', 'display_currency': package.currency_id}"/></dd></div>
                                    <div><dt>Nomor SPK</dt><dd><t t-esc="package.sp_number or '-'"/></dd></div>
                                    <div><dt>Tanggal SPK</dt><dd><t t-esc="package.sp_date or '-'"/></dd></div>
                                </dl>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="sr-card sr-card--detail h-100">
                                <div class="sr-card__top">
                                    <h3>Pengiriman &amp; Pemeriksaan</h3>
                                </div>
                                <dl class="sr-dl" style="grid-template-columns: 1fr;">
                                    <div><dt>Tanggal Pengiriman</dt><dd><t t-esc="package.delivery_date or '-'"/></dd></div>
                                    <div><dt>Hasil Pemeriksaan</dt><dd><span t-field="package.inspection_status"/></dd></div>
                                    <div><dt>Catatan Pemeriksaan</dt><dd><t t-esc="package.inspection_notes or '-'"/></dd></div>
                                    <div><dt>Catatan Penyelesaian</dt><dd><t t-esc="package.completion_notes or '-'"/></dd></div>
                                </dl>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ========================================== -->
    <!-- 3. TEMPLATE DAFTAR KONTRAK                 -->
    <!-- ========================================== -->
    <template id="portal_contracts" name="Daftar Kontrak Sadaya Rutin">
        <t t-call="sadaya_rutin.portal_rutin_layout">
            <t t-set="active_menu" t-value="'kontrak'"/>

            <section class="sr-page-header">
                <div class="container">
                    <p class="sr-kicker">Portal Operasional</p>
                    <h1>Daftar Kontrak Rutin</h1>
                    <p class="sr-lead">Dashboard > Daftar Kontrak</p>
                </div>
            </section>

            <section class="sr-section sr-section--form">
                <div class="container">
                    <form method="get" class="sr-form sr-form--inline mb-4">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="sr-field-label">Status</label>
                                <select name="status" class="form-select sr-input">
                                    <option value="">Semua Status</option>
                                    <t t-foreach="statuses" t-as="st">
                                        <option t-att-value="st[0]" t-att-selected="st[0] == filters.get('status')"><t t-esc="st[1]"/></option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="sr-field-label">Tanggal Mulai</label>
                                <input type="date" name="start_date" class="form-control sr-input" t-att-value="filters.get('start_date')"/>
                            </div>
                            <div class="col-md-3">
                                <label class="sr-field-label">Tanggal Selesai</label>
                                <input type="date" name="end_date" class="form-control sr-input" t-att-value="filters.get('end_date')"/>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-dark sr-submit w-100">Filter</button>
                            </div>
                        </div>
                    </form>

                    <div class="row g-3">
                        <t t-foreach="contracts" t-as="contract">
                            <div class="col-12 col-lg-6">
                                <article class="sr-card sr-card--detail">
                                    <div class="sr-card__top">
                                        <div>
                                            <span class="sr-label"><span t-field="contract.status"/></span>
                                            <h3><span t-field="contract.package_id.name"/></h3>
                                        </div>
                                        <strong><span t-field="contract.hps_value" t-options="{'widget': 'monetary', 'display_currency': contract.currency_id}"/></strong>
                                    </div>
                                    <dl class="sr-dl">
                                        <div><dt>Pejabat Pembuat</dt><dd><span t-field="contract.officer_name"/></dd></div>
                                        <div><dt>Penyedia</dt><dd><span t-field="contract.vendor_name"/></dd></div>
                                        <div><dt>Tanggal</dt><dd><span t-field="contract.start_date"/></dd></div>
                                    </dl>
                                </article>
                            </div>
                        </t>
                        <t t-if="not contracts">
                            <div class="col-12">
                                <div class="sr-card sr-empty-card p-4 text-center">
                                    Belum ada kontrak yang tersimpan untuk ditampilkan.
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </section>
        </t>
    </template>

</odoo>