<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!-- LANGKAH 1: DEFINISI GRUP                                    -->
        <!-- ============================================================ -->

        <record id="group_rutin_pp" model="res.groups">
            <field name="name">PP - Pejabat Pengadaan Rutin</field>
        </record>

        <record id="group_rutin_ppk" model="res.groups">
            <field name="name">PPK - Pejabat Pembuat Komitmen Rutin</field>
        </record>

        <record id="group_rutin_tim_teknis" model="res.groups">
            <field name="name">Tim Teknis Rutin</field>
        </record>

        <record id="group_rutin_pphp" model="res.groups">
            <field name="name">PPHP - Penerima Hasil Pekerjaan Rutin</field>
        </record>

        <record id="group_rutin_unit_kerja" model="res.groups">
            <field name="name">Unit Kerja Rutin (Viewer)</field>
        </record>

        <!-- ============================================================ -->
        <!-- LANGKAH 2: JADIKAN INTERNAL USER + ASSIGN GRUP              -->
        <!--                                                              -->
        <!-- Seed users di sadaya_auth tidak punya base.group_user,      -->
        <!-- sehingga mereka dianggap Portal User dan tidak bisa masuk   -->
        <!-- backend. Kita perbaiki di sini:                             -->
        <!--   (3, id) = HAPUS relasi (keluar dari portal group)         -->
        <!--   (4, id) = TAMBAH relasi (masuk ke internal user + grup)   -->
        <!-- ============================================================ -->

        <!-- Bob = PP (Pejabat Pengadaan) -->
        <record id="sadaya_auth.user_bob_pejabatpengadaan" model="res.users">
            <field name="group_ids" eval="[
                (3, ref('base.group_portal')),
                (4, ref('base.group_user')),
                (4, ref('sadaya_rutin.group_rutin_pp'))
            ]"/>
        </record>

        <!-- Smith = PPK -->
        <record id="sadaya_auth.user_smith_ppk" model="res.users">
            <field name="group_ids" eval="[
                (3, ref('base.group_portal')),
                (4, ref('base.group_user')),
                (4, ref('sadaya_rutin.group_rutin_ppk'))
            ]"/>
        </record>

        <!-- Arthur = Tim Teknis -->
        <record id="sadaya_auth.user_arthur_timteknis" model="res.users">
            <field name="group_ids" eval="[
                (3, ref('base.group_portal')),
                (4, ref('base.group_user')),
                (4, ref('sadaya_rutin.group_rutin_tim_teknis'))
            ]"/>
        </record>

        <!-- Dave = PPHP -->
        <record id="sadaya_auth.user_dave_pphp" model="res.users">
            <field name="group_ids" eval="[
                (3, ref('base.group_portal')),
                (4, ref('base.group_user')),
                (4, ref('sadaya_rutin.group_rutin_pphp'))
            ]"/>
        </record>

        <!-- Eve = Unit Kerja -->
        <record id="sadaya_auth.user_eve_unitkerja" model="res.users">
            <field name="group_ids" eval="[
                (3, ref('base.group_portal')),
                (4, ref('base.group_user')),
                (4, ref('sadaya_rutin.group_rutin_unit_kerja'))
            ]"/>
        </record>

        <!-- ============================================================ -->
        <!-- VENDOR: Pastikan Trent & Glory adalah Portal User           -->
        <!-- Vendor TIDAK boleh akses backend Odoo sama sekali.          -->
        <!-- Mereka hanya bisa akses via portal web (/sadaya-rutin/...). -->
        <!-- (3, id) = HAPUS dari Internal User                          -->
        <!-- (4, id) = MASUKKAN ke Portal User                           -->
        <!-- ============================================================ -->

        <!-- Trent (Vendor 1) -->
        <record id="sadaya_auth.user_trent_vendor" model="res.users">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_portal')])]"/>
        </record>

        <!-- Glory (Vendor 2) -->
        <record id="sadaya_auth.user_glory_vendor" model="res.users">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_portal')])]"/>
        </record>

        <!-- ============================================================ -->
        <!-- RECORD RULE: Vendor Portal                                   -->
        <!-- Vendor hanya melihat paket yang ditujukan ke mereka.        -->
        <!-- ============================================================ -->
        <record id="rule_rutin_vendor_paket_sendiri" model="ir.rule">
            <field name="name">Rutin: Vendor Hanya Lihat Paket Sendiri</field>
            <field name="model_id" ref="model_sadaya_rutin_procurement_package"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('vendor_id.user_ids', 'in', [user.id])]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

    </data>
</odoo>
