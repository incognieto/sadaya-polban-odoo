<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_list_paket_template" name="Daftar Paket Sadaya Tawar">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h2 class="mb-4">Portal Pengadaan - Sadaya Tawar</h2>
                <form method="get" action="/sadaya_tawar/paket" class="row g-2 mb-3">
                    <div class="col-md-6">
                        <input type="text" name="search" class="form-control" placeholder="Cari nama atau kode paket" t-att-value="search or ''"/>
                    </div>
                    <div class="col-md-4">
                        <select name="metode" class="form-select">
                            <option value="">Semua Metode</option>
                            <option value="e_purchasing" t-att-selected="metode == 'e_purchasing'">E-Purchasing</option>
                            <option value="pengadaan_langsung" t-att-selected="metode == 'pengadaan_langsung'">Pengadaan Langsung</option>
                            <option value="tender" t-att-selected="metode == 'tender'">Tender</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" type="submit">Cari</button>
                    </div>
                </form>
                <table class="table table-striped table-hover border">
                    <thead class="table-dark">
                        <tr>
                            <th>Kode Paket</th>
                            <th>Nama Paket</th>
                            <th>Metode Pemilihan</th>
                            <th>Nilai HPS</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="pakets" t-as="pkt">
                            <tr>
                                <td><t t-esc="pkt.kode_paket"/></td>
                                <td><strong><t t-esc="pkt.name"/></strong></td>
                                <td class="text-uppercase"><t t-esc="pkt.metode_pemilihan"/></td>
                                <td>Rp <t t-esc="'{:,}'.format(pkt.nilai_hps)"/></td>
                                <td>
                                    <a t-attf-href="/sadaya_tawar/paket/#{pkt.id}" class="btn btn-sm btn-primary">Lihat Detail</a>
                                </td>
                            </tr>
                        </t>
                        <tr t-if="not pakets">
                            <td colspan="5" class="text-center text-muted">Belum ada paket yang diumumkan.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <template id="portal_detail_paket_template" name="Detail Paket Sadaya Tawar">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5">
                <a href="/sadaya_tawar/paket" class="btn btn-outline-secondary mb-3">&amp;larr; Kembali ke Daftar</a>
                <div t-if="daftar == 'success'" class="alert alert-success">Pendaftaran berhasil. Tim akan memverifikasi data vendor Anda.</div>
                <div t-if="error == 'not_verified'" class="alert alert-warning">Akun vendor belum terverifikasi. Silakan lengkapi data di Sadaya Mitra.</div>
                <div t-if="error == 'already_registered'" class="alert alert-info">Vendor sudah terdaftar pada paket ini.</div>
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><t t-esc="paket.name"/></h4>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <p><strong>Kode Paket:</strong> <t t-esc="paket.kode_paket"/></p>
                                <p><strong>Metode Pemilihan:</strong> <t t-esc="paket.metode_pemilihan.replace('_', ' ').title()"/></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Jenis Kontrak:</strong> <t t-esc="paket.jenis_kontrak.replace('_', ' ').title()"/></p>
                                <p><strong>Nilai HPS:</strong> Rp <t t-esc="'{:,}'.format(paket.nilai_hps)"/></p>
                            </div>
                        </div>
                        <div class="alert alert-info">
                            <strong>Batas Pendaftaran:</strong> <t t-esc="paket.batas_pendaftaran or 'Belum ditentukan'"/>
                        </div>
                        <div class="mt-4">
                            <h5>Dokumen Addendum</h5>
                            <t t-if="paket.addendum_ids">
                                <ul class="list-group">
                                    <t t-foreach="paket.addendum_ids" t-as="doc">
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span>
                                                <t t-esc="doc.name"/>
                                                <t t-if="doc.dokumen_filename">(<t t-esc="doc.dokumen_filename"/>)</t>
                                            </span>
                                            <a t-attf-href="/web/content/sadaya_tawar.addendum/#{doc.id}/dokumen?download=true" class="btn btn-sm btn-outline-primary">Unduh</a>
                                        </li>
                                    </t>
                                </ul>
                            </t>
                            <div t-if="not paket.addendum_ids" class="text-muted">Belum ada addendum.</div>
                        </div>

                        <div class="mt-4 text-end">
                            <t t-if="can_register and not is_registered">
                                <form method="post" t-attf-action="/sadaya_tawar/paket/#{paket.id}/daftar">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button class="btn btn-success btn-lg" type="submit">Daftar Sebagai Peserta</button>
                                </form>
                            </t>
                            <t t-if="is_registered">
                                <span class="badge bg-success">Sudah Terdaftar</span>
                            </t>
                            <t t-if="not can_register">
                                <div class="alert alert-warning mt-2">Harap login sebagai vendor terdaftar untuk mendaftar.</div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>