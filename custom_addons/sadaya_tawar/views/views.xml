<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_sadaya_tawar_paket" model="ir.sequence">
        <field name="name">Sadaya Tawar Kode Paket</field>
        <field name="code">sadaya.tawar.paket.seq</field>
        <field name="prefix">PKT/TAWAR/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="view_sadaya_tawar_paket_list" model="ir.ui.view">
        <field name="name">sadaya_tawar.paket.list</field>
        <field name="model">sadaya_tawar.paket</field>
        <field name="arch" type="xml">
            <list>
                <field name="kode_paket"/>
                <field name="name"/>
                <field name="jenis_pengadaan"/> <field name="metode_pemilihan"/>
                <field name="nilai_hps"/>
                <field name="jenis_kontrak"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_sadaya_tawar_paket_form" model="ir.ui.view">
        <field name="name">sadaya_tawar.paket.form</field>
        <field name="model">sadaya_tawar.paket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publikasikan" string="Publikasikan ke Sadaya Tawar" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_set_eval" string="Masuk Evaluasi" type="object" class="oe_highlight" invisible="state != 'published'"/>
                    <button name="action_route_paket" string="Kirim ke Modul Eksekusi (Otomatis)" type="object" class="oe_highlight" invisible="state != 'eval'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,eval,routed" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="kode_paket"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="nilai_hps"/>
                            <field name="jenis_pengadaan"/> <field name="jenis_kontrak"/>
                        </group>
                        <group>
                            <field name="metode_pemilihan"/>
                            <field name="batas_pendaftaran"/>
                            <field name="unit_pengusul"/>
                            <field name="tgl_mulai"/>
                            <field name="tgl_selesai"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dokumen Persiapan">
                            <group>
                                <field name="deskripsi" placeholder="Tuliskan deskripsi atau ruang lingkup singkat..."/>
                                <!-- Tambahan Field Persyaratan -->
                                <field name="syarat_kbli" placeholder="Contoh: 6201, 6202"/>
                                <field name="syarat_dokumen" placeholder="Sebutkan dokumen administratif atau teknis tambahan yang perlu disiapkan vendor..."/>
                            </group>
                            <group>
                                <field name="deskripsi" placeholder="Tuliskan deskripsi atau ruang lingkup singkat..."/>
                            </group>
                            <group col="4">
                                <field name="dokumen_kak" filename="filename_kak" widget="binary"/>
                                <field name="filename_kak" invisible="1"/>
                                
                                <field name="dokumen_spektek" filename="filename_spektek" widget="binary"/>
                                <field name="filename_spektek" invisible="1"/>
                                
                                <field name="dokumen_rab" filename="filename_rab" widget="binary"/>
                                <field name="filename_rab" invisible="1"/>
                            </group>
                        </page>

                        <page string="Peserta">
                            <field name="peserta_ids">
                                <list editable="bottom">
                                    <field name="vendor_id"/>
                                    <field name="tanggal_daftar"/>
                                    <field name="status"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="vendor_id"/>
                                        <field name="tanggal_daftar"/>
                                        <field name="status"/>
                                        <field name="catatan"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        
                        <page string="Addendum">
                            <field name="addendum_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="tanggal"/>
                                    <field name="dokumen" filename="dokumen_filename" widget="binary"/>
                                    <field name="dokumen_filename" column_invisible="1"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="tanggal"/>
                                        <field name="dokumen" filename="dokumen_filename"/>
                                        <field name="keterangan"/>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <page string="Jadwal Tahapan">
                            <field name="jadwal_ids">
                                <list editable="bottom">
                                    <field name="name" placeholder="Misal: Penjelasan (Aanwijzing), Upload Penawaran..."/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sadaya_tawar_paket" model="ir.actions.act_window">
        <field name="name">Paket Pengadaan (RUP)</field>
        <field name="res_model">sadaya_tawar.paket</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sadaya_tawar_root" name="Sadaya Tawar" sequence="10"/>
    <menuitem id="menu_sadaya_tawar_paket" name="Daftar RUP" parent="menu_sadaya_tawar_root" action="action_sadaya_tawar_paket" sequence="10"/>
</odoo>