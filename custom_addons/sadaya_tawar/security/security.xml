<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_tawar_admin" model="res.groups">
            <field name="name">Admin Sadaya Tawar (PPK/POKJA)</field>
            <field name="user_ids" eval="[
                (4, ref('sadaya_auth.user_smith_ppk')),
                (4, ref('sadaya_auth.user_alice_pokja')),
                (4, ref('base.user_admin')) 
            ]"/>
        </record>

        <record id="group_tawar_viewer" model="res.groups">
            <field name="name">Viewer Sadaya Tawar (Read-Only)</field>
            <field name="user_ids" eval="[
                (4, ref('sadaya_auth.user_jane_manajemen')),
                (4, ref('sadaya_auth.user_eve_unitkerja')),
                (4, ref('sadaya_auth.user_bob_pejabatpengadaan'))
            ]"/>
        </record>

        <record id="group_tawar_vendor" model="res.groups">
            <field name="name">Vendor Sadaya Tawar</field>
            <field name="user_ids" eval="[
                (4, ref('sadaya_auth.user_trent_vendor')),
                (4, ref('sadaya_auth.user_glory_vendor'))
            ]"/>
        </record>

        <record id="rule_vendor_lihat_penawaran_sendiri" model="ir.rule">
            <field name="name">Vendor Hanya Melihat Penawarannya Sendiri</field>
            <field name="model_id" ref="model_sadaya_tawar_peserta"/>
            <field name="groups" eval="[(4, ref('sadaya_tawar.group_tawar_vendor'))]"/>
            <field name="domain_force">[('vendor_id.user_ids', 'in', [user.id])]</field>
        </record>
    </data>
</odoo>