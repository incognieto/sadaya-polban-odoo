<odoo>

    <!-- LIST -->
    <record id="view_sadaya_mitra_penyedia_tree" model="ir.ui.view">
        <field name="name">sadaya_mitra.penyedia.tree</field>
        <field name="model">sadaya_mitra.penyedia</field>
        <field name="arch" type="xml">
            <list>
                <field name="nama_badan_usaha"/>
                <field name="jenis_penyedia"/>
                <field name="email"/>
                <field name="status_verifikasi" widget="badge" decoration-success="status_verifikasi=='approved'" decoration-danger="status_verifikasi=='rejected'"/>
            </list>
        </field>
    </record>

    <!-- FORM BESAR -->
    <record id="view_sadaya_mitra_penyedia_form" model="ir.ui.view">
        <field name="name">sadaya_mitra.penyedia.form</field>
        <field name="model">sadaya_mitra.penyedia</field>
        <field name="arch" type="xml">
            <form string="Penyedia">
                <header>
                    <button name="action_approve" string="Setujui" type="object" class="btn-success" invisible="status_verifikasi != 'draft'"/>
                    <button name="action_reject" string="Tolak" type="object" class="btn-danger" invisible="status_verifikasi != 'draft'"/>
                    <button name="action_reset" string="Kembali ke Draft" type="object" class="btn-secondary" invisible="status_verifikasi in ('draft',)"/>
                    <field name="status_verifikasi" widget="statusbar" options="{'clickable': False}" statusbar_visible="draft,approved,rejected"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Disetujui" bg_color="text-bg-success" invisible="status_verifikasi != 'approved'"/>
                    <widget name="web_ribbon" title="Ditolak" bg_color="text-bg-danger" invisible="status_verifikasi != 'rejected'"/>

                    <field name="swafoto_narahubung" widget="image" class="oe_avatar" options="{'preview_image': 'swafoto_narahubung', 'size': [128, 128]}"/>

                    <div class="oe_title">
                        <label for="nama_badan_usaha" class="oe_edit_only" string="Nama Badan Usaha"/>
                        <h1>
                            <field name="nama_badan_usaha" placeholder="Cth: PT Sukses Selalu"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Informasi Dasar">
                            <field name="jenis_penyedia" widget="radio" options="{'horizontal': true}"/>
                            <field name="alamat"/>
                            <field name="nomor_npwp_perusahaan"/>
                            <field name="bukti_npwp" widget="binary"/>
                        </group>
                        <group string="Kontak &amp; Narahubung">
                            <field name="narahubung"/>
                            <field name="nomor_nik_narahubung"/>
                            <field name="email" widget="email"/>
                            <field name="nomor_telepon" widget="phone"/>
                            <field name="nomor_whatsapp" widget="phone"/>
                        </group>
                        <group string="Status &amp; Verifikasi">
                            <field name="data_lengkap_count" readonly="1" decoration-info="1"/>
                            <field name="tanggal_verifikasi" readonly="1" invisible="status_verifikasi != 'approved'"/>
                        </group>
                    </group>

                    <div class="alert alert-danger mt-3" role="alert" invisible="status_verifikasi != 'rejected'">
                        <h5 class="alert-heading mb-1"><i class="fa fa-exclamation-triangle me-2"/>Alasan Penolakan</h5>
                        <field name="catatan_verifikasi" readonly="1" nolabel="1"/>
                    </div>

                    <notebook>

                        <page string="Landasan Hukum">
                            <field name="landasan_hukum_id"/>
                        </page>

                        <page string="Pengurus">
                            <field name="pengurus_ids"/>
                        </page>

                        <page string="Izin Usaha">
                            <field name="izin_usaha_ids"/>
                        </page>

                        <page string="Sertifikat Perusahaan">
                            <field name="sertifikat_perusahaan_ids"/>
                        </page>

                        <page string="Kepemilikan Saham">
                            <field name="saham_ids"/>
                        </page>

                        <page string="Personalia">
                            <field name="personalia_ids"/>
                        </page>

                        <page string="Kantor">
                            <field name="kantor_ids"/>
                        </page>

                        <page string="Fasilitas">
                            <field name="fasilitas_ids"/>
                        </page>

                        <page string="Pengalaman Perusahaan">
                            <field name="pengalaman_perusahaan_ids"/>
                        </page>

                        <page string="Keuangan">
                            <field name="keuangan_id"/>
                        </page>

                        <page string="Pajak">
                            <field name="pajak_id"/>
                        </page>

                        <page string="Pendaftaran DPT">
                            <field name="pendaftaran_dpt_ids"/>
                        </page>

                        <page string="Pengajuan TTE">
                            <field name="tte_ids"/>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sadaya_mitra_penyedia" model="ir.actions.act_window">
        <field name="name">Penyedia</field>
        <field name="res_model">sadaya_mitra.penyedia</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_sadaya_mitra_root" name="Sadaya Mitra"/>
    <menuitem id="menu_sadaya_mitra_penyedia"
              parent="menu_sadaya_mitra_root"
              action="action_sadaya_mitra_penyedia"
              name="Penyedia"/>
</odoo>