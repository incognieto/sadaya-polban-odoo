<odoo>

    <!-- LIST -->
    <record id="view_sadaya_mitra_penyedia_tree" model="ir.ui.view">
        <field name="name">sadaya_mitra.penyedia.tree</field>
        <field name="model">sadaya_mitra.penyedia</field>
        <field name="arch" type="xml">
            <list>
                <field name="nama_badan_usaha"/>
                <field name="jenis_penyedia"/>
                <field name="email"/>
                <field name="status_verifikasi" widget="badge" decoration-success="status_verifikasi=='approved'" decoration-danger="status_verifikasi=='rejected'"/>
            </list>
        </field>
    </record>

    <!-- FORM BESAR -->
    <record id="view_sadaya_mitra_penyedia_form" model="ir.ui.view">
        <field name="name">sadaya_mitra.penyedia.form</field>
        <field name="model">sadaya_mitra.penyedia</field>
        <field name="arch" type="xml">
            <form string="Penyedia">
                <header>
                    <button name="action_approve" string="Setujui" type="object" class="oe_highlight" invisible="status_verifikasi != 'draft'"/>
                    <button name="action_reject" string="Tolak" type="object" invisible="status_verifikasi != 'draft'"/>
                    <button name="action_reset" string="Kembali ke Draft" type="object" invisible="status_verifikasi in ('draft',)"/>
                    <field name="status_verifikasi" widget="statusbar" options="{'clickable': False}"/>
                </header>
                <sheet>
                    <div class="alert alert-info" invisible="status_verifikasi != 'rejected'">
                        <strong>Catatan Penolakan:</strong>
                        <p>
                            <field name="catatan_verifikasi" readonly="1" class="mt-2"/>
                        </p>
                    </div>

                    <div class="alert alert-success" invisible="status_verifikasi != 'approved'">
                        <strong>Disetujui pada:</strong>
                        <field name="tanggal_verifikasi" readonly="1"/>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h2 class="mb-3">Informasi Dasar Penyedia</h2>
                        </div>
                        <div class="col-md-6 text-end">
                            <p class="text-muted mb-0">Kelengkapan Data: <strong><field name="data_lengkap_count" readonly="1" class="fw-bold"/></strong></p>
                        </div>
                    </div>

                    <group>
                        <field name="jenis_penyedia"/>
                        <field name="nama_badan_usaha"/>
                        <field name="email"/>
                        <field name="nomor_telepon"/>
                        <field name="nomor_whatsapp"/>
                        <field name="narahubung"/>
                        <field name="nomor_nik_narahubung"/>
                        <field name="swafoto_narahubung"/>
                        <field name="alamat"/>
                        <field name="nomor_npwp_perusahaan"/>
                        <field name="bukti_npwp"/>
                    </group>

                    <notebook>

                        <page string="Landasan Hukum">
                            <field name="landasan_hukum_id"/>
                        </page>

                        <page string="Pengurus">
                            <field name="pengurus_ids"/>
                        </page>

                        <page string="Izin Usaha">
                            <field name="izin_usaha_ids"/>
                        </page>

                        <page string="Sertifikat Perusahaan">
                            <field name="sertifikat_perusahaan_ids"/>
                        </page>

                        <page string="Kepemilikan Saham">
                            <field name="saham_ids"/>
                        </page>

                        <page string="Personalia">
                            <field name="personalia_ids"/>
                        </page>

                        <page string="Kantor">
                            <field name="kantor_ids"/>
                        </page>

                        <page string="Fasilitas">
                            <field name="fasilitas_ids"/>
                        </page>

                        <page string="Pengalaman Perusahaan">
                            <field name="pengalaman_perusahaan_ids"/>
                        </page>

                        <page string="Keuangan">
                            <field name="keuangan_id"/>
                        </page>

                        <page string="Pajak">
                            <field name="pajak_id"/>
                        </page>

                        <page string="Pendaftaran DPT">
                            <field name="pendaftaran_dpt_ids"/>
                        </page>

                        <page string="Pengajuan TTE">
                            <field name="tte_ids"/>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sadaya_mitra_penyedia" model="ir.actions.act_window">
        <field name="name">Penyedia</field>
        <field name="res_model">sadaya_mitra.penyedia</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_sadaya_mitra_root" name="Sadaya Mitra"/>
    <menuitem id="menu_sadaya_mitra_penyedia"
              parent="menu_sadaya_mitra_root"
              action="action_sadaya_mitra_penyedia"
              name="Penyedia"/>
</odoo>