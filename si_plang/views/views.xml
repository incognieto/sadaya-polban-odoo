<odoo>
  <data>

    <!-- ========== PAKET VIEWS ========== -->

    <record model="ir.ui.view" id="si_plang_paket_list">
      <field name="name">si_plang.paket.list</field>
      <field name="model">si_plang.paket</field>
      <field name="arch" type="xml">
        <list string="Paket Penyedia" decoration-success="status_paket == 'selesai_kontrak'"
              decoration-warning="status_paket in ('revisi','addendum_kontrak')"
              decoration-danger="status_paket == 'batal'"
              decoration-info="status_paket in ('proses_penawaran','negosiasi_penyedia','negosiasi_pp')">
          <field name="name" string="Nama Paket"/>
          <field name="unit_pengusul" string="Unit Pengusul"/>
          <field name="jenis_pengadaan" string="Jenis Pengadaan"/>
          <field name="nilai_hps" string="Nilai HPS" widget="float"/>
          <field name="status_paket" string="Status" widget="badge"
                 decoration-success="status_paket == 'selesai_kontrak'"
                 decoration-warning="status_paket in ('revisi','addendum_kontrak')"
                 decoration-danger="status_paket == 'batal'"
                 decoration-info="status_paket in ('proses_penawaran','negosiasi_penyedia','negosiasi_pp')"
                 decoration-muted="status_paket in ('acara_negosiasi','proses_ba_negosiasi','negosiasi_selesai','persiapan_kontrak','proses_kontrak')"/>
          <field name="tanggal" string="Tanggal"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="si_plang_paket_form">
      <field name="name">si_plang.paket.form</field>
      <field name="model">si_plang.paket</field>
      <field name="arch" type="xml">
        <form string="Paket Penyedia">
          <header>
            <field name="status_paket" widget="statusbar"
                   statusbar_visible="proses_penawaran,negosiasi_penyedia,negosiasi_selesai,persiapan_kontrak,proses_kontrak,selesai_kontrak"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="name" placeholder="Nama Paket..." required="True"/>
              </h1>
            </div>
            <group>
              <group string="Informasi Paket">
                <field name="unit_pengusul"/>
                <field name="jenis_pengadaan"/>
                <field name="nilai_hps" widget="float"/>
              </group>
              <group string="Jadwal">
                <field name="tanggal"/>
                <field name="tanggal_mulai"/>
                <field name="tanggal_selesai"/>
              </group>
            </group>
            <group string="Keterangan">
              <field name="keterangan" nolabel="1"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="si_plang_paket_action_window">
      <field name="name">Paket Penyedia</field>
      <field name="res_model">si_plang.paket</field>
      <field name="view_mode">list,form</field>
      <field name="context">{}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Belum ada paket tersedia.
        </p>
        <p>Klik tombol <b>Baru</b> untuk menambahkan paket pertama Anda.</p>
      </field>
    </record>

    <!-- ========== KONTRAK VIEWS ========== -->

    <record model="ir.ui.view" id="si_plang_kontrak_list">
      <field name="name">si_plang.kontrak.list</field>
      <field name="model">si_plang.kontrak</field>
      <field name="arch" type="xml">
        <list string="Daftar Kontrak"
              decoration-success="status_kontrak == 'selesai_kontrak'"
              decoration-warning="status_kontrak in ('revisi','addendum_kontrak')"
              decoration-info="status_kontrak == 'proses_kontrak'">
          <field name="name" string="Nama Paket"/>
          <field name="pejabat_pembuat" string="Pejabat Pembuat"/>
          <field name="penyedia" string="Penyedia"/>
          <field name="jenis_pengadaan" string="Jenis Pengadaan"/>
          <field name="nilai_hps" string="Nilai HPS" widget="float"/>
          <field name="status_kontrak" string="Status" widget="badge"
                 decoration-success="status_kontrak == 'selesai_kontrak'"
                 decoration-warning="status_kontrak in ('revisi','addendum_kontrak')"
                 decoration-info="status_kontrak == 'proses_kontrak'"
                 decoration-muted="status_kontrak == 'persiapan_kontrak'"/>
          <field name="tanggal" string="Tanggal"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="si_plang_kontrak_form">
      <field name="name">si_plang.kontrak.form</field>
      <field name="model">si_plang.kontrak</field>
      <field name="arch" type="xml">
        <form string="Kontrak">
          <header>
            <field name="status_kontrak" widget="statusbar"
                   statusbar_visible="persiapan_kontrak,proses_kontrak,selesai_kontrak"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="name" placeholder="Nama Paket..." required="True"/>
              </h1>
            </div>
            <group>
              <group string="Informasi Kontrak">
                <field name="paket_id"/>
                <field name="pejabat_pembuat"/>
                <field name="penyedia"/>
                <field name="jenis_pengadaan"/>
                <field name="nilai_hps" widget="float"/>
              </group>
              <group string="Jadwal Kontrak">
                <field name="tanggal"/>
                <field name="tanggal_mulai"/>
                <field name="tanggal_selesai"/>
              </group>
            </group>
            <group string="Keterangan">
              <field name="keterangan" nolabel="1"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="si_plang_kontrak_action_window">
      <field name="name">Kontrak</field>
      <field name="res_model">si_plang.kontrak</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Belum ada kontrak tersedia.
        </p>
        <p>Klik tombol <b>Baru</b> untuk membuat kontrak pertama Anda.</p>
      </field>
    </record>

    <!-- ========== DASHBOARD ACTION ========== -->

    <record model="ir.actions.client" id="si_plang_dashboard_action">
      <field name="name">Dashboard Si-PLang</field>
      <field name="tag">si_plang_dashboard</field>
    </record>

    <!-- ========== MENU ========== -->

    <menuitem name="Si-PLang"
              id="si_plang_menu_root"
              web_icon="si_plang,static/description/icon.png"
              sequence="10"/>

    <menuitem name="Dashboard"
              id="si_plang_menu_dashboard"
              parent="si_plang_menu_root"
              action="si_plang_paket_action_window"
              sequence="1"/>

    <menuitem name="Paket"
              id="si_plang_menu_paket"
              parent="si_plang_menu_root"
              action="si_plang_paket_action_window"
              sequence="2"/>

    <menuitem name="Kontrak"
              id="si_plang_menu_kontrak"
              parent="si_plang_menu_root"
              action="si_plang_kontrak_action_window"
              sequence="3"/>

  </data>
</odoo>
