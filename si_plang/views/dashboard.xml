<odoo>
  <data>
    <template id="si_plang_dashboard_template">
      <t t-name="si_plang_dashboard">
        <div class="si_plang_dashboard o_view_controller">
          <!-- Header Banner -->
          <div class="o_view_sample_data_alert" style="
              background: linear-gradient(135deg, #e8faf4 0%, #d0f5e8 100%);
              border-radius: 16px;
              padding: 40px 48px;
              margin: 24px 24px 0 24px;
              display: flex;
              align-items: center;
              justify-content: space-between;
          ">
            <div>
              <div style="display:flex; gap:8px; margin-bottom:12px;">
                <span style="background:#1a9e6e;color:white;border-radius:20px;padding:4px 14px;font-size:13px;">Transparansi</span>
                <span style="background:#1a9e6e;color:white;border-radius:20px;padding:4px 14px;font-size:13px;">Akuntabilitas</span>
                <span style="background:#1a9e6e;color:white;border-radius:20px;padding:4px 14px;font-size:13px;">Efisiensi</span>
              </div>
              <div style="font-size:13px;color:#555;background:white;border-radius:8px;display:inline-block;padding:4px 12px;margin-bottom:16px;">
                ✦ Modul Unggulan
              </div>
              <h1 style="font-size:28px;font-weight:800;color:#222;margin-bottom:8px;">
                Si-PLang — <span style="color:#1a9e6e;">Sistem Informasi</span> Pembelian Langsung
              </h1>
              <p style="color:#555;font-size:14px;max-width:500px;">
                Sistem Informasi Pembelian Langsung untuk mengelola transaksi pengadaan barang dan jasa secara efisien dan transparan.
              </p>
                <button type="button" t-on-click="openPaket" style="
                  display:inline-block;margin-top:8px;
                  border:1px solid #1a9e6e;color:#1a9e6e;
                  border-radius:8px;padding:8px 20px;
                  text-decoration:none;font-weight:600;
                  background:transparent;cursor:pointer;
                ">Lihat Paket</button>
            </div>
          </div>

          <!-- Feature Cards -->
          <div style="display:flex;gap:20px;margin:24px 24px;">

            <!-- Card 1 -->
            <div style="flex:1;background:white;border-radius:14px;padding:28px;box-shadow:0 2px 12px rgba(0,0,0,0.07);border:1px solid #f0f0f0;">
              <div style="width:44px;height:44px;background:#f59e0b;border-radius:10px;margin-bottom:16px;"></div>
              <h3 style="font-size:16px;font-weight:700;margin-bottom:8px;color:#222;">Ajukan Permintaan Pembelian</h3>
              <p style="color:#777;font-size:13px;line-height:1.6;">
                Buat dan kelola permintaan pengadaan barang/jasa secara digital — dari kebutuhan hingga persetujuan pejabat berwenang, semua dalam satu alur.
              </p>
              <button type="button" t-on-click="openPaket" style="color:#1a9e6e;font-weight:600;font-size:13px;text-decoration:none;background:transparent;border:none;padding:0;cursor:pointer;">Mulai Cepat →</button>
            </div>

            <!-- Card 2 -->
            <div style="flex:1;background:white;border-radius:14px;padding:28px;box-shadow:0 2px 12px rgba(0,0,0,0.07);border:1px solid #f0f0f0;">
              <div style="display:flex;gap:4px;flex-wrap:wrap;width:44px;margin-bottom:16px;">
                <div style="width:18px;height:18px;background:#ef4444;border-radius:4px;"></div>
                <div style="width:18px;height:18px;background:#3b82f6;border-radius:4px;"></div>
                <div style="width:18px;height:18px;background:#22c55e;border-radius:4px;"></div>
                <div style="width:18px;height:18px;background:#f59e0b;border-radius:4px;"></div>
              </div>
              <h3 style="font-size:16px;font-weight:700;margin-bottom:8px;color:#222;">Kelola Kontrak</h3>
              <p style="color:#777;font-size:13px;line-height:1.6;">
                Pantau masa berlaku, nilai kontrak, dan progres pelaksanaan pekerjaan dengan mudah. Semua dokumen tersimpan dan mudah diakses kapan saja.
              </p>
              <button type="button" t-on-click="openKontrak" style="color:#1a9e6e;font-weight:600;font-size:13px;text-decoration:none;background:transparent;border:none;padding:0;cursor:pointer;">Manajemen Kontrak →</button>
            </div>

            <!-- Card 3 -->
            <div style="flex:1;background:white;border-radius:14px;padding:28px;box-shadow:0 2px 12px rgba(0,0,0,0.07);border:1px solid #f0f0f0;">
              <div style="width:44px;height:44px;background:#16a34a;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;color:white;font-weight:800;font-size:16px;">31</div>
              <h3 style="font-size:16px;font-weight:700;margin-bottom:8px;color:#222;">Atur Jadwal &amp; Prioritas Pengadaan</h3>
              <p style="color:#777;font-size:13px;line-height:1.6;">
                Rencanakan proses pengadaan dengan timeline yang jelas. Tetapkan prioritas, atur tenggat waktu, dan pastikan semua berjalan sesuai jadwal.
              </p>
              <button type="button" t-on-click="openPaket" style="color:#1a9e6e;font-weight:600;font-size:13px;text-decoration:none;background:transparent;border:none;padding:0;cursor:pointer;">Perencanaan →</button>
            </div>

          </div>
        </div>
      </t>
    </template>
  </data>
</odoo>
